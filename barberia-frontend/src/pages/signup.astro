---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Button from "@/components/fundations/elements/Button.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
---

<BaseLayout>
  <section class="bg-base-950 min-h-[calc(100dvh-4rem)] flex items-center">
    <Wrapper variant="standard" class="py-20">
      <div class="max-w-sm mx-auto">
        <Text
          tag="h1"
          variant="displaySM"
          class="tracking-tight font-semibold text-base-50 font-display"
        >
          Crear cuenta
        </Text>
        <Text
          tag="p"
          variant="textBase"
          data-signup-subtitle
          class="mt-4 text-base-400 font-medium text-balance"
        >
          Únete y comienza a reservar citas en tu barbería favorita.
        </Text>
        <p
          id="plan-notice"
          class="hidden mt-4 p-3 rounded-lg bg-accent-900/30 border border-accent-800/50 text-sm text-accent-200"
        >
          <span id="plan-notice-text"></span>
        </p>
        <a href="/" class="inline-flex items-center gap-1 text-xs text-base-500 hover:text-accent-400 mt-2 transition-colors">
          ← Ver planes y funciones
        </a>

        <div
          id="form-error"
          class="hidden mt-6 p-3 rounded-lg bg-red-900/40 border border-red-700/50"
        >
          <p class="text-sm text-red-400" id="form-error-text"></p>
        </div>

        <form id="signup-form" class="mx-auto mt-8" novalidate>
          <div class="flex flex-col gap-y-6">
            <input type="hidden" id="plan-field" name="plan" value="" />
            <div id="business-wrap" class="hidden">
              <label for="business-name" class="text-sm text-base-400 font-medium">
                Nombre del negocio <span class="text-accent-500">*</span>
              </label>
              <div class="mt-2.5">
                <input
                  type="text"
                  name="businessName"
                  id="business-name"
                  autocomplete="organization"
                  minlength="2"
                  maxlength="120"
                  placeholder="Ej. Barbería El Corte"
                  class="block w-full h-10 px-4 py-2 text-sm text-base-100 duration-300 bg-base-900 border border-transparent rounded-lg appearance-none ring-1 ring-base-700 placeholder-base-600 focus:border-transparent focus:outline-none focus:ring-accent-500 focus:ring-offset-2 focus:ring-offset-base-950 focus:ring-2 sm:text-sm"
                />
              </div>
              <p class="mt-1 text-xs text-base-500">Será el nombre de tu espacio en Barbería (plan con 14 días gratis).</p>
            </div>
            <div>
              <label for="full-name" class="text-sm text-base-400 font-medium">
                Tu nombre completo
              </label>
              <div class="mt-2.5">
                <input
                  type="text"
                  name="fullName"
                  id="full-name"
                  autocomplete="name"
                  required
                  aria-required="true"
                  minlength="2"
                  maxlength="120"
                  class="block w-full h-10 px-4 py-2 text-sm text-base-100 duration-300 bg-base-900 border border-transparent rounded-lg appearance-none ring-1 ring-base-700 placeholder-base-600 focus:border-transparent focus:outline-none focus:ring-accent-500 focus:ring-offset-2 focus:ring-offset-base-950 focus:ring-2 sm:text-sm"
                />
              </div>
            </div>
            <div>
              <label for="email" class="text-sm text-base-400 font-medium">
                Correo electrónico
              </label>
              <div class="mt-2.5">
                <input
                  type="email"
                  name="email"
                  id="email"
                  autocomplete="email"
                  required
                  aria-required="true"
                  class="block w-full h-10 px-4 py-2 text-sm text-base-100 duration-300 bg-base-900 border border-transparent rounded-lg appearance-none ring-1 ring-base-700 placeholder-base-600 focus:border-transparent focus:outline-none focus:ring-accent-500 focus:ring-offset-2 focus:ring-offset-base-950 focus:ring-2 sm:text-sm"
                />
              </div>
            </div>
            <div>
              <label for="password" class="text-sm text-base-400 font-medium">
                Contraseña
              </label>
              <div class="mt-2.5">
                <input
                  type="password"
                  name="password"
                  id="password"
                  autocomplete="new-password"
                  required
                  aria-required="true"
                  minlength="8"
                  maxlength="128"
                  class="block w-full h-10 px-4 py-2 text-sm text-base-100 duration-300 bg-base-900 border border-transparent rounded-lg appearance-none ring-1 ring-base-700 placeholder-base-600 focus:border-transparent focus:outline-none focus:ring-accent-500 focus:ring-offset-2 focus:ring-offset-base-950 focus:ring-2 sm:text-sm"
                />
                <p class="mt-1 text-xs text-base-500">Mínimo 8 caracteres</p>
              </div>
            </div>
          </div>
          <div class="flex items-center mt-6 gap-3">
            <input
              id="agreement"
              name="agreement"
              type="checkbox"
              required
              class="size-4 rounded border-base-600 bg-base-800 text-accent-500 focus:ring-accent-500 shadow"
            />
            <label class="block text-sm text-base-400" for="agreement">
              Acepto los
              <a class="text-accent-400 hover:text-accent-300" href="/terms">
                Términos de uso
              </a>
              y la
              <a class="text-accent-400 hover:text-accent-300" href="/terms">
                Política de privacidad
              </a>
            </label>
          </div>
          <Button
            id="submit-btn"
            variant="default"
            size="base"
            class="mt-8 w-full"
          >
            Crear cuenta
          </Button>
          <div class="flex items-center mt-4">
            <Text tag="p" variant="textSM" class="text-base-500">
              ¿Ya tienes cuenta?
              <a class="text-accent-400 hover:text-accent-300" href="/login">
                Iniciar sesión
              </a>
            </Text>
          </div>
        </form>
      </div>
    </Wrapper>
  </section>
</BaseLayout>

<script>
  import { isAuthenticated, saveSession } from "@/lib/auth";
  import { getApiV1Url } from "@/lib/config";

  function getRoleRedirect(roles: string[]): string {
    const r = roles.map(x => x.toUpperCase());
    if (r.includes("ADMIN") || r.includes("RECEPTIONIST")) return "/dashboard/";
    return "/dashboard/appointments";
  }

  if (isAuthenticated()) {
    const u = JSON.parse(localStorage.getItem("user") ?? "{}");
    window.location.href = getRoleRedirect(u.roles ?? []);
  }

  const VALID_PLANS = ["BASIC", "PROFESSIONAL", "ENTERPRISE", "TRIAL"] as const;
  const PLAN_LABELS: Record<string, string> = {
    BASIC: "Básico",
    PROFESSIONAL: "Profesional",
    ENTERPRISE: "Enterprise",
    TRIAL: "Prueba",
  };

  const sp = new URLSearchParams(window.location.search);
  const rawPlan = sp.get("plan");
  const selectedPlan =
    rawPlan && VALID_PLANS.includes(rawPlan as (typeof VALID_PLANS)[number])
      ? rawPlan
      : null;

  const planField = document.getElementById("plan-field") as HTMLInputElement | null;
  const businessWrap = document.getElementById("business-wrap");
  const businessNameInput = document.getElementById("business-name") as HTMLInputElement | null;
  const planNotice = document.getElementById("plan-notice");
  const planNoticeText = document.getElementById("plan-notice-text");
  const subEl = document.querySelector("[data-signup-subtitle]");

  if (selectedPlan && planField && businessWrap && businessNameInput && planNotice && planNoticeText) {
    planField.value = selectedPlan;
    businessWrap.classList.remove("hidden");
    businessNameInput.required = true;
    planNotice.classList.remove("hidden");
    const label = PLAN_LABELS[selectedPlan] ?? selectedPlan;
    planNoticeText.textContent = `Estás registrando tu barbería con el plan ${label} — 14 días gratis.`;
    if (subEl)
      subEl.textContent =
        "Crea tu cuenta de administrador y configura tu negocio en minutos.";
  }

  const form = document.getElementById(
    "signup-form"
  ) as HTMLFormElement | null;
  const errorBox = document.getElementById("form-error") as HTMLElement | null;
  const errorText = document.getElementById(
    "form-error-text"
  ) as HTMLElement | null;
  const submitBtn = document.getElementById(
    "submit-btn"
  ) as HTMLButtonElement | null;
  const agreement = document.getElementById(
    "agreement"
  ) as HTMLInputElement | null;

  function showError(msg: string) {
    if (errorText) errorText.textContent = msg;
    errorBox?.classList.remove("hidden");
  }

  function hideError() {
    errorBox?.classList.add("hidden");
  }

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    hideError();

    if (!agreement?.checked) {
      showError("Debes aceptar los términos para continuar.");
      return;
    }

    const fd = new FormData(form);
    const fullName = (fd.get("fullName") as string).trim();
    const email = (fd.get("email") as string).trim();
    const password = fd.get("password") as string;
    const businessName = (fd.get("businessName") as string | null)?.trim() ?? "";
    const planFromForm = (fd.get("plan") as string | null)?.trim() || null;

    if (!fullName || !email || !password) {
      showError("Por favor completa todos los campos.");
      return;
    }
    if (password.length < 8) {
      showError("La contraseña debe tener al menos 8 caracteres.");
      return;
    }
    if (planFromForm && (!businessName || businessName.length < 2)) {
      showError("Indica el nombre de tu barbería o negocio.");
      return;
    }

    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = "Creando cuenta…";
    }

    const apiBase = getApiV1Url();

    try {
      const regBody: Record<string, string> = { fullName, email, password };
      if (planFromForm && businessName) {
        regBody.businessName = businessName;
        regBody.plan = planFromForm;
      }

      const regRes = await fetch(`${apiBase}/auth/register`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(regBody),
      });

      if (!regRes.ok) {
        const err = (await regRes.json().catch(() => ({}))) as {
          message?: string;
        };
        throw new Error(err.message ?? "Error al crear la cuenta");
      }

      const loginRes = await fetch(`${apiBase}/auth/login`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ email, password }),
      });

      if (!loginRes.ok) {
        window.location.href = "/login";
        return;
      }

      const body = (await loginRes.json()) as {
        data: {
          user: {
            id: string;
            email: string;
            fullName: string;
            roles: string[];
            tenantId?: string | null;
          };
          tokens: { accessToken: string; refreshToken: string };
        };
      };

      const u = body.data.user;
      saveSession(
        {
          id: u.id,
          email: u.email,
          fullName: u.fullName,
          roles: u.roles,
          tenantId: u.tenantId ?? null,
        },
        body.data.tokens.accessToken,
        body.data.tokens.refreshToken
      );
      window.location.href = getRoleRedirect(body.data.user.roles);
    } catch (err) {
      showError(err instanceof Error ? err.message : "Error al crear la cuenta");
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = "Crear cuenta";
      }
    }
  });
</script>
