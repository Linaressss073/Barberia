---
import DashboardLayout from "@/layouts/DashboardLayout.astro";
---
<DashboardLayout title="Inicio" section="home">

  <!-- Staff view -->
  <div id="view-staff" class="hidden space-y-6">

    <!-- Alertas críticas (inventario bajo) -->
    <div id="alerts-section" class="hidden space-y-2">
      <div id="alerts-list" class="space-y-2"></div>
    </div>

    <!-- Plan strip (admin only) -->
    <div id="admin-tenant-strip" class="hidden flex flex-wrap items-center gap-3 rounded-xl border border-base-800 bg-base-900 px-4 py-3">
      <span id="tenant-plan-badge" class="text-xs font-semibold uppercase tracking-wide px-2.5 py-1 rounded-full bg-accent-900/50 text-accent-400 border border-accent-800/40"></span>
      <span id="tenant-trial-info" class="text-sm text-base-400"></span>
      <span id="tenant-barber-usage" class="text-sm text-base-300 ml-auto"></span>
    </div>

    <!-- KPIs del día -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
      <div class="bg-base-900 rounded-xl border border-base-800 p-5">
        <p class="text-xs font-medium uppercase tracking-widest text-base-500">Citas hoy</p>
        <p id="s-total" class="mt-2 text-3xl font-semibold text-base-50 font-display">—</p>
      </div>
      <div class="bg-base-900 rounded-xl border border-base-800 p-5">
        <p class="text-xs font-medium uppercase tracking-widest text-base-500">Confirmadas</p>
        <p id="s-confirmed" class="mt-2 text-3xl font-semibold text-accent-400 font-display">—</p>
      </div>
      <div class="bg-base-900 rounded-xl border border-base-800 p-5">
        <p class="text-xs font-medium uppercase tracking-widest text-base-500">Completadas</p>
        <p id="s-completed" class="mt-2 text-3xl font-semibold text-green-400 font-display">—</p>
      </div>
      <div class="bg-base-900 rounded-xl border border-base-800 p-5">
        <p class="text-xs font-medium uppercase tracking-widest text-base-500">Canceladas</p>
        <p id="s-cancelled" class="mt-2 text-3xl font-semibold text-red-400 font-display">—</p>
      </div>
    </div>

    <!-- Ingresos + ocupación -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div class="bg-base-900 rounded-xl border border-base-800 p-5">
        <p class="text-xs font-medium uppercase tracking-widest text-base-500">Ingresos del día</p>
        <p id="s-income" class="mt-2 text-2xl font-semibold text-base-50 font-display">—</p>
        <p class="mt-1 text-xs text-base-500">De citas completadas</p>
      </div>
      <div class="bg-base-900 rounded-xl border border-base-800 p-5">
        <p class="text-xs font-medium uppercase tracking-widest text-base-500">Pendientes</p>
        <p id="s-pending" class="mt-2 text-2xl font-semibold text-yellow-400 font-display">—</p>
        <p class="mt-1 text-xs text-base-500">Sin confirmar aún</p>
      </div>
    </div>

    <!-- Quick links -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <a href="/dashboard/appointments" class="bg-base-900 border border-base-800 rounded-xl p-5 hover:border-accent-700/50 transition-colors group">
        <p class="text-xs font-medium uppercase tracking-widest text-base-500 group-hover:text-accent-500 transition-colors">Citas de hoy</p>
        <p class="mt-1 text-sm text-base-400">Ver todas las citas →</p>
      </a>
      <a href="/dashboard/customers" class="bg-base-900 border border-base-800 rounded-xl p-5 hover:border-accent-700/50 transition-colors group" id="link-customers">
        <p class="text-xs font-medium uppercase tracking-widest text-base-500 group-hover:text-accent-500 transition-colors">Clientes</p>
        <p class="mt-1 text-sm text-base-400">Gestionar clientes →</p>
      </a>
      <a href="/dashboard/sales" class="bg-base-900 border border-base-800 rounded-xl p-5 hover:border-accent-700/50 transition-colors group">
        <p class="text-xs font-medium uppercase tracking-widest text-base-500 group-hover:text-accent-500 transition-colors">Ventas</p>
        <p class="mt-1 text-sm text-base-400">Abrir caja →</p>
      </a>
    </div>
  </div>

  <!-- Customer view -->
  <div id="view-customer" class="hidden space-y-6">
    <div class="bg-base-900 rounded-xl border border-base-800 p-6">
      <p class="text-xs font-medium uppercase tracking-widest text-base-500">Puntos de lealtad</p>
      <p id="loyalty-pts" class="mt-2 text-4xl font-semibold text-accent-400 font-display">—</p>
      <p class="mt-1 text-sm text-base-500">Acumulados en tu barbería activa</p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <a href="/dashboard/appointments" class="bg-base-900 border border-base-800 rounded-xl p-5 hover:border-accent-700/50 transition-colors group">
        <p class="text-xs font-medium uppercase tracking-widest text-base-500 group-hover:text-accent-500 transition-colors">Mis citas</p>
        <p class="mt-1 text-sm text-base-400">Ver próximas citas →</p>
      </a>
      <a id="link-book" href="/dashboard/book" class="bg-accent-900/30 border border-accent-800/40 rounded-xl p-5 hover:border-accent-600/50 transition-colors group">
        <p class="text-xs font-medium uppercase tracking-widest text-accent-600 group-hover:text-accent-400 transition-colors">Reservar cita</p>
        <p class="mt-1 text-sm text-accent-700">Elegir servicio y horario →</p>
      </a>
    </div>
    <!-- Last visited barbers -->
    <div id="recent-barbers-section" class="hidden">
      <h3 class="text-sm font-medium text-base-400 mb-3">Barberías recientes</h3>
      <div id="recent-barbers-list" class="grid grid-cols-1 sm:grid-cols-3 gap-3"></div>
    </div>
  </div>

</DashboardLayout>

<script>
  import { getUser } from "@/lib/auth";
  import { apiFetch } from "@/lib/api";

  const user = getUser()!;
  const roles = user.roles.map((r) => r.toUpperCase());
  const isStaff = roles.some((r) => ["ADMIN","RECEPTIONIST","BARBER"].includes(r));
  const isAdmin = roles.includes("ADMIN");

  function show(id: string) { document.getElementById(id)?.classList.remove("hidden"); }
  function fmtCents(c: number) {
    return (c / 100).toLocaleString("es-CO", { style: "currency", currency: "COP", maximumFractionDigits: 0 });
  }

  if (isStaff) {
    show("view-staff");

    // ── Admin-only: plan strip + inventory alerts ─────────────────────────────
    if (isAdmin) {
      show("admin-tenant-strip");

      Promise.all([
        apiFetch("/tenants/me").catch(() => null),
        apiFetch("/barbers?page=1&limit=500&onlyActive=true").catch(() => ({ total: 0 })),
        apiFetch("/inventory/products/low-stock").catch(() => []),
      ]).then(([tenant, barbersPage, lowStock]) => {
        // Plan strip
        if (tenant) {
          const planLabels: Record<string, string> = { TRIAL:"Prueba", BASIC:"Básico", PROFESSIONAL:"Profesional", ENTERPRISE:"Enterprise" };
          document.getElementById("tenant-plan-badge")!.textContent = planLabels[tenant.plan] ?? tenant.plan;
          if (tenant.trialEndsAt && tenant.plan === "TRIAL") {
            const days = Math.max(0, Math.ceil((new Date(tenant.trialEndsAt).getTime() - Date.now()) / 86400000));
            document.getElementById("tenant-trial-info")!.textContent = `Prueba gratuita · ${days} día${days !== 1 ? "s" : ""} restantes`;
          }
          const n = barbersPage?.total ?? (barbersPage as any)?.items?.length ?? 0;
          const max = tenant.maxBarbers;
          document.getElementById("tenant-barber-usage")!.textContent =
            max === -1 ? `Barberos: ${n} (ilimitado)` : `Barberos: ${n} / ${max}`;
        }

        // Inventory alerts
        const items: any[] = Array.isArray(lowStock) ? lowStock : (lowStock as any)?.items ?? [];
        if (items.length > 0) {
          show("alerts-section");
          const list = document.getElementById("alerts-list")!;
          list.innerHTML = items.slice(0, 5).map((p: any) => `
            <div class="flex items-center gap-3 rounded-xl border border-orange-800/40 bg-orange-900/20 px-4 py-3">
              <svg class="size-4 text-orange-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v4m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/></svg>
              <span class="text-sm text-orange-300">Stock bajo: <strong>${p.name}</strong> — ${p.stock} unidades (mínimo ${p.minStock})</span>
              <a href="/dashboard/inventory" class="ml-auto text-xs text-orange-400 hover:text-orange-300 shrink-0">Ver →</a>
            </div>`).join("");
          if (items.length > 5) {
            list.innerHTML += `<p class="text-xs text-orange-400 pl-1">+ ${items.length - 5} productos más con stock bajo</p>`;
          }
        }
      });
    }

    // ── Today's KPIs ─────────────────────────────────────────────────────────
    const now = new Date();
    const from = new Date(now); from.setHours(0,0,0,0);
    const to = new Date(now); to.setHours(23,59,59,999);
    apiFetch(`/appointments?from=${from.toISOString()}&to=${to.toISOString()}&limit=200&page=1`)
      .then((data: any) => {
        const apts = data.items ?? [];
        const completed = apts.filter((a: any) => a.status === "COMPLETED");
        const income = completed.reduce((sum: number, a: any) => sum + (a.items ?? []).reduce((s: number, it: any) => s + (it.priceCents ?? 0), 0), 0);
        document.getElementById("s-total")!.textContent = String(apts.length);
        document.getElementById("s-confirmed")!.textContent = String(apts.filter((a: any) => a.status === "CONFIRMED").length);
        document.getElementById("s-pending")!.textContent = String(apts.filter((a: any) => a.status === "BOOKED").length);
        document.getElementById("s-completed")!.textContent = String(completed.length);
        document.getElementById("s-cancelled")!.textContent = String(apts.filter((a: any) => a.status === "CANCELLED").length);
        document.getElementById("s-income")!.textContent = fmtCents(income);
      })
      .catch(() => {});

  } else {
    show("view-customer");

    (async () => {
      const { getSelectedTenantId, syncActiveTenantFromServer } = await import("@/lib/tenant-context");
      let tenantId = getSelectedTenantId();
      if (!tenantId) tenantId = await syncActiveTenantFromServer();

      const bookLink = document.getElementById("link-book") as HTMLAnchorElement;
      if (!tenantId && bookLink) bookLink.href = "/explore";

      // Loyalty points from customer_tenants for active barbershop
      if (tenantId) {
        apiFetch("/customer-tenants/mine").then((list: any) => {
          const records = Array.isArray(list) ? list : list?.items ?? [];
          const active = records.find((r: any) => r.isActive || r.tenantId === tenantId);
          document.getElementById("loyalty-pts")!.textContent = active ? String(active.loyaltyPoints) : "0";

          // Recent barbers
          const recent = records.slice(0, 3);
          if (recent.length > 0) {
            show("recent-barbers-section");
            document.getElementById("recent-barbers-list")!.innerHTML = recent.map((r: any) => `
              <a href="/explore/${r.tenantId}" class="rounded-xl border ${r.isActive ? "border-accent-700/50 bg-accent-900/10" : "border-base-800 bg-base-900/80"} p-4 hover:border-accent-600/50 transition-colors">
                <p class="text-base-100 font-medium text-sm">${r.tenantName ?? r.tenantId}</p>
                <p class="text-xs text-base-500 mt-1">${r.loyaltyPoints} pts · ${r.visitCount} visita${r.visitCount !== 1 ? "s" : ""}</p>
                ${r.isActive ? '<span class="text-xs text-accent-400">Activa</span>' : ""}
              </a>`).join("");
          }
        }).catch(() => {
          apiFetch("/customers/me").then((c: any) => {
            document.getElementById("loyalty-pts")!.textContent = c ? String(c.loyaltyPoints) : "0";
          }).catch(() => {});
        });
      } else {
        document.getElementById("loyalty-pts")!.textContent = "—";
      }
    })();
  }
</script>
