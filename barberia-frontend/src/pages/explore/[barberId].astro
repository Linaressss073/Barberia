---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
---
<BaseLayout>
  <Wrapper class="pt-28 pb-20">
    <!-- Back link -->
    <a href="/explore" class="inline-flex items-center gap-1 text-sm text-base-500 hover:text-accent-400 mb-8 transition-colors">
      ← Todas las barberías
    </a>

    <!-- Loading skeleton / error -->
    <div id="page-loading" class="text-center text-base-500 text-sm py-12">Cargando barbería…</div>
    <div id="page-error" class="hidden text-center text-rose-400 text-sm py-12"></div>

    <!-- Content (hidden until loaded) -->
    <div id="page-content" class="hidden space-y-10">

      <!-- Header -->
      <div class="flex flex-col sm:flex-row gap-4 sm:items-start sm:justify-between">
        <div>
          <h1 id="tenant-name" class="text-2xl font-bold font-display text-base-50"></h1>
          <p id="tenant-slug" class="text-base-500 text-sm mt-1"></p>
        </div>
        <button id="btn-book-here"
          class="px-6 py-3 text-sm font-semibold rounded-xl bg-accent-500 text-base-950 hover:bg-accent-400 transition-colors shrink-0">
          Reservar aquí
        </button>
      </div>

      <!-- Services -->
      <div>
        <h2 class="text-base-100 font-semibold text-lg mb-4">Servicios</h2>
        <div id="services-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3"></div>
      </div>

      <!-- Barbers -->
      <div>
        <h2 class="text-base-100 font-semibold text-lg mb-4">Equipo</h2>
        <div id="barbers-grid" class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3"></div>
      </div>

    </div>
  </Wrapper>
</BaseLayout>

<script>
  import { apiFetchPublic } from "@/lib/api";
  import { setActiveTenantWithSync } from "@/lib/tenant-context";
  import { isAuthenticated } from "@/lib/auth";

  const barberId = window.location.pathname.split("/").pop()!;

  function fmtCents(c: number) {
    return (c / 100).toLocaleString("es-CO", { style: "currency", currency: "COP", maximumFractionDigits: 0 });
  }

  (async () => {
    try {
      const data = await apiFetchPublic<{
        id: string; name: string; slug: string;
        services: { id: string; name: string; description: string | null; durationMin: number; priceCents: number }[];
        barbers: { id: string; displayName: string; specialty: string | null; ratingAvg: string }[];
      }>(`/tenants/${barberId}/public`);

      document.getElementById("page-loading")!.classList.add("hidden");
      document.getElementById("page-content")!.classList.remove("hidden");

      document.getElementById("tenant-name")!.textContent = data.name;
      document.getElementById("tenant-slug")!.textContent = `/${data.slug}`;
      document.title = `${data.name} — Barbería`;

      // Services
      const svcGrid = document.getElementById("services-grid")!;
      if (data.services.length === 0) {
        svcGrid.innerHTML = '<p class="text-base-500 text-sm col-span-full">Sin servicios publicados aún.</p>';
      } else {
        svcGrid.innerHTML = data.services.map(s => `
          <div class="rounded-xl border border-base-800 bg-base-900/80 p-4">
            <p class="text-base-100 font-medium text-sm">${escHtml(s.name)}</p>
            ${s.description ? `<p class="text-base-500 text-xs mt-1 line-clamp-2">${escHtml(s.description)}</p>` : ""}
            <div class="flex gap-3 mt-3">
              <span class="text-xs text-base-500">${s.durationMin} min</span>
              <span class="text-xs font-semibold text-accent-400">${fmtCents(s.priceCents)}</span>
            </div>
          </div>`).join("");
      }

      // Barbers
      const barberGrid = document.getElementById("barbers-grid")!;
      if (data.barbers.length === 0) {
        barberGrid.innerHTML = '<p class="text-base-500 text-sm col-span-full">Sin barberos registrados aún.</p>';
      } else {
        barberGrid.innerHTML = data.barbers.map(b => `
          <div class="rounded-xl border border-base-800 bg-base-900/80 p-4 flex flex-col items-center gap-2 text-center">
            <div class="size-12 rounded-full bg-accent-900/50 flex items-center justify-center text-accent-400 font-semibold text-lg">
              ${escHtml(b.displayName[0].toUpperCase())}
            </div>
            <p class="text-base-100 font-medium text-sm">${escHtml(b.displayName)}</p>
            ${b.specialty ? `<p class="text-base-500 text-xs">${escHtml(b.specialty)}</p>` : ""}
            <p class="text-xs text-accent-400">★ ${parseFloat(b.ratingAvg).toFixed(1)}</p>
          </div>`).join("");
      }

      // Book button
      document.getElementById("btn-book-here")!.addEventListener("click", async () => {
        if (!isAuthenticated()) {
          window.location.href = `/login?returnUrl=/explore/${barberId}`;
          return;
        }
        const btn = document.getElementById("btn-book-here") as HTMLButtonElement;
        btn.disabled = true;
        btn.textContent = "Guardando…";
        await setActiveTenantWithSync(data.id);
        window.location.href = "/dashboard/book";
      });

    } catch (err) {
      document.getElementById("page-loading")!.classList.add("hidden");
      const errEl = document.getElementById("page-error")!;
      errEl.textContent = (err as Error).message ?? "No se pudo cargar la barbería.";
      errEl.classList.remove("hidden");
    }
  })();

  function escHtml(s: string) {
    return s.replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;");
  }
</script>
