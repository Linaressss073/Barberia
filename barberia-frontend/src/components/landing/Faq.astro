---
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import Plus from "@/components/fundations/icons/Plus.astro";

const faqs = [
  {
    question: "¿Cómo funciona la reserva de citas online?",
    answer:
      "Los clientes crean una cuenta, eligen el servicio deseado, seleccionan su barbero favorito y consultan los horarios disponibles. Todo el proceso toma menos de 2 minutos desde cualquier dispositivo.",
  },
  {
    question: "¿Puedo gestionar múltiples barberos?",
    answer:
      "Sí. Cada barbero tiene su propio perfil con horario, bloques de tiempo, especialidad y comisiones independientes. El administrador puede configurar todo desde el panel.",
  },
  {
    question: "¿Las notificaciones llegan por WhatsApp?",
    answer:
      "El módulo de WhatsApp está en proceso de configuración. Las notificaciones por email ya están disponibles desde el primer día. WhatsApp estará activo próximamente.",
  },
  {
    question: "¿Cómo funciona el programa de lealtad?",
    answer:
      "Cada visita otorga puntos al cliente. Cuando acumula suficientes, puede canjearlos por descuentos o servicios gratuitos. El administrador define cuántos puntos equivalen a cada recompensa.",
  },
  {
    question: "¿Qué métodos de pago registra el sistema?",
    answer:
      "El sistema registra pagos en efectivo, tarjeta de crédito/débito, transferencia bancaria y otros medios que el administrador configure. No procesa pagos directamente, solo los registra.",
  },
  {
    question: "¿Puedo controlar el inventario de productos?",
    answer:
      "Sí. El módulo de inventario permite registrar productos, controlar el stock, registrar movimientos de entrada y salida, y configurar alertas cuando un producto llega al mínimo.",
  },
  {
    question: "¿Hay prueba gratuita?",
    answer:
      "Sí, ofrecemos 14 días de prueba gratuita con acceso completo a todas las funciones del plan Profesional. No se requiere tarjeta de crédito para empezar.",
  },
  {
    question: "¿El sistema funciona desde el celular?",
    answer:
      "Totalmente. La interface es responsive y está optimizada para usarse desde smartphone, tablet o computadora sin necesidad de instalar ninguna aplicación.",
  },
  {
    question: "¿Puedo cancelar mi suscripción en cualquier momento?",
    answer:
      "Sí, puedes cancelar cuando quieras desde la configuración de tu cuenta. Te daremos la opción de exportar todos tus datos antes de cerrar.",
  },
  {
    question: "¿Cómo migro mis datos actuales al sistema?",
    answer:
      "Ofrecemos importación de clientes y servicios mediante archivos CSV. Para migraciones más complejas, nuestro equipo puede acompañarte durante el proceso de onboarding.",
  },
];
---

<section id="faq">
  <Wrapper variant="standard" class="py-20">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 lg:gap-12">
      <div>
        <Text
          tag="span"
          variant="textSM"
          class="leading-normal font-bold uppercase text-accent-700"
        >
          FAQ
        </Text>
        <Text
          tag="h2"
          variant="displayMD"
          class="tracking-tight mt-4 font-semibold text-base-900"
        >
          Preguntas frecuentes
        </Text>
        <Text
          tag="p"
          variant="textBase"
          class="mt-4 text-base-500 font-medium text-balance"
        >
          Todo lo que necesitas saber sobre el sistema de gestión para barberías.
        </Text>
      </div>
      <div class="lg:col-span-2">
        {
          faqs.map((faq) => (
            <details class="group pb-4">
              <summary class="cursor-pointer flex items-center justify-between w-full text-left font-medium select-none text-base-600 hover:text-accent-800">
                <Text tag="h3" variant="textLG">
                  {faq.question}
                </Text>
                <Plus class="size-5 duration-300 ease-out text-base-500 group-open:rotate-45" />
              </summary>
              <Text
                tag="p"
                variant="textBase"
                class="pb-4 pt-2 text-base-500 text-balance"
              >
                {faq.answer}
              </Text>
            </details>
          ))
        }
      </div>
    </div>
  </Wrapper>
</section>
