---
import Text from "@/components/fundations/elements/Text.astro";
import Button from "@/components/fundations/elements/Button.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";

const cards = [
  {
    eyebrow: "Para clientes",
    title: "¿Eres Cliente?",
    description:
      "Crea tu cuenta gratis y reserva citas online en minutos. Elige tu barbero favorito, revisa disponibilidad y recibe recordatorios automáticos.",
    cta: "Crear Cuenta Gratis",
    href: "/signup",
    variant: "default",
    dark: false,
  },
  {
    eyebrow: "Para el negocio",
    title: "¿Eres Barbero o Dueño?",
    description:
      "Administra tu negocio desde un panel completo: agenda, clientes, ventas e inventario. Todo organizado en un solo lugar.",
    cta: "Iniciar Sesión",
    href: "/login",
    variant: "muted",
    dark: true,
  },
];
---

<section>
  <Wrapper variant="standard" class="py-20">
    <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
      {
        cards.map((card) => (
          <div
            class:list={[
              "flex flex-col justify-between gap-8 p-8 rounded-2xl border border-base-200",
              card.dark ? "bg-accent-950" : "bg-base-50 ring-4 ring-base-50",
            ]}
          >
            <div>
              <Text
                tag="span"
                variant="textSM"
                class:list={[
                  "leading-normal font-bold uppercase",
                  card.dark ? "text-accent-300" : "text-accent-700",
                ]}
              >
                {card.eyebrow}
              </Text>
              <Text
                tag="h3"
                variant="displaySM"
                class:list={[
                  "mt-3 font-semibold tracking-tight",
                  card.dark ? "text-white" : "text-base-900",
                ]}
              >
                {card.title}
              </Text>
              <Text
                tag="p"
                variant="textBase"
                class:list={[
                  "mt-3 font-medium",
                  card.dark ? "text-base-300" : "text-base-500",
                ]}
              >
                {card.description}
              </Text>
            </div>
            <Button
              isLink
              size="sm"
              variant={card.variant}
              href={card.href}
              class="w-fit"
            >
              {card.cta}
            </Button>
          </div>
        ))
      }
    </div>
  </Wrapper>
</section>
