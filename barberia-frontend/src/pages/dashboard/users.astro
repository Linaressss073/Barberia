---
import DashboardLayout from "@/layouts/DashboardLayout.astro";
---
<DashboardLayout title="Usuarios" section="users">

  <div class="space-y-5">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row gap-3 sm:items-center sm:justify-between">
      <div class="flex gap-2 flex-wrap">
        <input id="search-input" type="text" placeholder="Buscar usuario…"
          class="bg-base-900 ring-1 ring-base-700 text-base-100 focus:ring-accent-500 focus:ring-2 focus:outline-none rounded-lg px-3 py-2 text-sm w-48 sm:w-64" />
        <select id="filter-role" class="bg-base-900 ring-1 ring-base-700 text-base-100 focus:ring-accent-500 focus:ring-2 focus:outline-none rounded-lg px-3 py-2 text-sm">
          <option value="">Todos los roles</option>
          <option value="ADMIN">Admin</option>
          <option value="RECEPTIONIST">Recepcionista</option>
          <option value="BARBER">Barbero</option>
          <option value="CUSTOMER">Cliente</option>
        </select>
        <select id="filter-status" class="bg-base-900 ring-1 ring-base-700 text-base-100 focus:ring-accent-500 focus:ring-2 focus:outline-none rounded-lg px-3 py-2 text-sm">
          <option value="">Todos</option>
          <option value="ACTIVE">Activos</option>
          <option value="DISABLED">Deshabilitados</option>
          <option value="PENDING">Pendientes</option>
        </select>
        <button id="btn-search" class="px-4 py-2 text-sm rounded-lg bg-base-800 text-base-100 hover:bg-base-700 border border-base-700">Buscar</button>
      </div>
      <button id="btn-open-create" class="px-4 py-2 text-sm font-medium rounded-lg bg-accent-500 text-base-950 hover:bg-accent-400 shrink-0">+ Nuevo Usuario</button>
    </div>

    <!-- Table -->
    <div class="bg-base-900 border border-base-800 rounded-xl overflow-hidden">
      <table class="w-full">
        <thead>
          <tr class="bg-base-800/60">
            <th class="px-4 py-3 text-left text-xs font-medium text-base-500 uppercase tracking-widest">Nombre</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-base-500 uppercase tracking-widest hidden md:table-cell">Email</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-base-500 uppercase tracking-widest hidden sm:table-cell">Roles</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-base-500 uppercase tracking-widest">Estado</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-base-500 uppercase tracking-widest hidden lg:table-cell">Último acceso</th>
            <th class="px-4 py-3 text-right text-xs font-medium text-base-500 uppercase tracking-widest">Acciones</th>
          </tr>
        </thead>
        <tbody id="users-body" class="divide-y divide-base-800"></tbody>
      </table>
      <div id="users-empty" class="hidden p-12 text-center text-base-500 text-sm">No hay usuarios registrados.</div>
      <div id="users-loading" class="p-8 text-center text-base-500 text-sm">Cargando usuarios…</div>
    </div>

    <!-- Pagination -->
    <div class="flex items-center justify-between">
      <button id="btn-prev" disabled class="px-4 py-2 text-sm rounded-lg bg-base-800 text-base-100 hover:bg-base-700 border border-base-700 disabled:opacity-40 disabled:cursor-not-allowed">← Anterior</button>
      <span id="page-info" class="text-sm text-base-500">Página 1</span>
      <button id="btn-next" disabled class="px-4 py-2 text-sm rounded-lg bg-base-800 text-base-100 hover:bg-base-700 border border-base-700 disabled:opacity-40 disabled:cursor-not-allowed">Siguiente →</button>
    </div>
  </div>

  <!-- Add user modal -->
  <div id="modal-create" class="fixed inset-0 z-50 flex items-center justify-center bg-black/60 hidden">
    <div class="bg-base-900 border border-base-800 rounded-2xl p-6 w-full max-w-lg mx-4 shadow-2xl">
      <h3 class="text-base-100 font-semibold text-lg mb-4">Agregar Usuario</h3>

      <!-- Tabs -->
      <div class="flex gap-1 bg-base-800/60 rounded-xl p-1 mb-5">
        <button id="tab-auto" class="modal-tab flex-1 py-1.5 text-sm rounded-lg font-medium transition-colors bg-base-700 text-base-100">
          Buscar cuenta existente
        </button>
        <button id="tab-manual" class="modal-tab flex-1 py-1.5 text-sm rounded-lg font-medium transition-colors text-base-400 hover:text-base-100">
          Crear nuevo usuario
        </button>
      </div>

      <!-- Modo automático -->
      <div id="panel-auto" class="space-y-4">
        <p class="text-xs text-base-500">Escribe el email de alguien que ya tiene cuenta en la plataforma para vincularla a tu barbería.</p>
        <div class="flex gap-2">
          <input id="lookup-email" type="email" placeholder="email@ejemplo.com"
            class="flex-1 bg-base-950 ring-1 ring-base-700 text-base-100 focus:ring-accent-500 focus:ring-2 focus:outline-none rounded-lg px-3 py-2 text-sm" />
          <button id="btn-lookup" class="px-4 py-2 text-sm rounded-lg bg-base-800 text-base-100 hover:bg-base-700 border border-base-700 shrink-0">Buscar</button>
        </div>
        <div id="lookup-result" class="hidden rounded-xl border border-base-700 bg-base-800/40 p-4 space-y-3">
          <div class="flex items-center gap-3">
            <div id="lookup-avatar" class="size-9 rounded-full bg-accent-900/50 flex items-center justify-center text-accent-400 font-semibold text-sm shrink-0"></div>
            <div>
              <p id="lookup-name" class="text-base-100 font-medium text-sm"></p>
              <p id="lookup-email-display" class="text-base-500 text-xs"></p>
            </div>
          </div>
          <input type="hidden" id="lookup-user-id" />
          <div>
            <label class="text-xs uppercase tracking-widest text-base-500 block mb-2">Asignar rol</label>
            <div class="flex flex-wrap gap-3">
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="checkbox" class="assign-role-check rounded" value="BARBER" />
                <span class="text-sm text-base-300">Barbero</span>
              </label>
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="checkbox" class="assign-role-check rounded" value="RECEPTIONIST" />
                <span class="text-sm text-base-300">Recepcionista</span>
              </label>
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="checkbox" class="assign-role-check rounded" value="ADMIN" />
                <span class="text-sm text-base-300">Administrador</span>
              </label>
            </div>
          </div>
        </div>
        <div id="lookup-not-found" class="hidden text-sm text-red-400">No se encontró ningún usuario con ese email.</div>
        <div class="flex justify-end gap-2 pt-1">
          <button id="create-close-auto" class="px-4 py-2 text-sm rounded-lg bg-base-800 text-base-100 hover:bg-base-700 border border-base-700">Cancelar</button>
          <button id="assign-submit" disabled class="px-5 py-2 text-sm font-medium rounded-lg bg-accent-500 text-base-950 hover:bg-accent-400 disabled:opacity-40 disabled:cursor-not-allowed">Vincular</button>
        </div>
      </div>

      <!-- Modo manual -->
      <div id="panel-manual" class="hidden space-y-4">
        <p class="text-xs text-base-500">Crea una cuenta nueva. El usuario podrá cambiar su contraseña más adelante.</p>
        <div>
          <label class="text-xs uppercase tracking-widest text-base-500">Nombre completo *</label>
          <input id="u-fullname" type="text" placeholder="Nombre completo"
            class="mt-1 bg-base-950 ring-1 ring-base-700 text-base-100 focus:ring-accent-500 focus:ring-2 focus:outline-none rounded-lg px-3 py-2 text-sm w-full" />
        </div>
        <div>
          <label class="text-xs uppercase tracking-widest text-base-500">Email *</label>
          <input id="u-email" type="email" placeholder="usuario@ejemplo.com"
            class="mt-1 bg-base-950 ring-1 ring-base-700 text-base-100 focus:ring-accent-500 focus:ring-2 focus:outline-none rounded-lg px-3 py-2 text-sm w-full" />
        </div>
        <div>
          <label class="text-xs uppercase tracking-widest text-base-500">Contraseña temporal *</label>
          <input id="u-password" type="password" placeholder="Mínimo 8 caracteres"
            class="mt-1 bg-base-950 ring-1 ring-base-700 text-base-100 focus:ring-accent-500 focus:ring-2 focus:outline-none rounded-lg px-3 py-2 text-sm w-full" />
        </div>
        <div>
          <label class="text-xs uppercase tracking-widest text-base-500 block mb-2">Roles *</label>
          <div class="flex flex-wrap gap-3">
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="checkbox" class="role-check rounded" value="BARBER" />
              <span class="text-sm text-base-300">Barbero</span>
            </label>
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="checkbox" class="role-check rounded" value="RECEPTIONIST" />
              <span class="text-sm text-base-300">Recepcionista</span>
            </label>
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="checkbox" class="role-check rounded" value="ADMIN" />
              <span class="text-sm text-base-300">Administrador</span>
            </label>
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="checkbox" class="role-check rounded" value="CUSTOMER" />
              <span class="text-sm text-base-300">Cliente</span>
            </label>
          </div>
        </div>
        <div class="flex justify-end gap-2 pt-1">
          <button id="create-close-manual" class="px-4 py-2 text-sm rounded-lg bg-base-800 text-base-100 hover:bg-base-700 border border-base-700">Cancelar</button>
          <button id="create-submit" class="px-5 py-2 text-sm font-medium rounded-lg bg-accent-500 text-base-950 hover:bg-accent-400">Crear Usuario</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Edit roles modal -->
  <div id="modal-roles" class="fixed inset-0 z-50 flex items-center justify-center bg-black/60 hidden">
    <div class="bg-base-900 border border-base-800 rounded-2xl p-6 w-full max-w-md mx-4 shadow-2xl">
      <h3 class="text-base-100 font-semibold text-lg mb-2">Cambiar Roles</h3>
      <p id="roles-modal-user" class="text-sm text-base-400 mb-5"></p>
      <input type="hidden" id="roles-user-id" />
      <div>
        <label class="text-xs uppercase tracking-widest text-base-500 block mb-3">Roles</label>
        <div class="space-y-2">
          <label class="flex items-center gap-3 cursor-pointer">
            <input type="checkbox" class="edit-role-check rounded" value="ADMIN" />
            <span class="text-sm text-base-300">Administrador</span>
          </label>
          <label class="flex items-center gap-3 cursor-pointer">
            <input type="checkbox" class="edit-role-check rounded" value="RECEPTIONIST" />
            <span class="text-sm text-base-300">Recepcionista</span>
          </label>
          <label class="flex items-center gap-3 cursor-pointer">
            <input type="checkbox" class="edit-role-check rounded" value="BARBER" />
            <span class="text-sm text-base-300">Barbero</span>
          </label>
          <label class="flex items-center gap-3 cursor-pointer">
            <input type="checkbox" class="edit-role-check rounded" value="CUSTOMER" />
            <span class="text-sm text-base-300">Cliente</span>
          </label>
        </div>
      </div>
      <div class="flex justify-end gap-2 mt-6">
        <button id="roles-close" class="px-4 py-2 text-sm rounded-lg bg-base-800 text-base-100 hover:bg-base-700 border border-base-700">Cancelar</button>
        <button id="roles-submit" class="px-5 py-2 text-sm font-medium rounded-lg bg-accent-500 text-base-950 hover:bg-accent-400">Guardar Roles</button>
      </div>
    </div>
  </div>

</DashboardLayout>

<script>
  import { getUser } from "@/lib/auth";
  import { apiFetch } from "@/lib/api";

  const user = getUser();
  const roles = user.roles.map(r => r.toUpperCase());
  if (!roles.includes("ADMIN")) {
    window.location.href = "/dashboard/";
    throw new Error("redirect");
  }

  let page = 1;
  let totalPages = 1;
  let search = "";
  let filterRole = "";
  let filterStatus = "";

  const STATUS_BADGES = {
    ACTIVE:   "bg-green-900/40 text-green-400 border border-green-800/40",
    DISABLED: "bg-red-900/40 text-red-400 border border-red-800/40",
    PENDING:  "bg-yellow-900/40 text-yellow-400 border border-yellow-800/40",
  };
  const STATUS_LABELS = { ACTIVE: "Activo", DISABLED: "Deshabilitado", PENDING: "Pendiente" };

  function fmtDate(iso) {
    if (!iso) return "—";
    return new Date(iso).toLocaleString("es-CO", { day: "numeric", month: "short", year: "numeric", hour: "2-digit", minute: "2-digit" });
  }

  async function loadUsers() {
    const body = document.getElementById("users-body");
    const empty = document.getElementById("users-empty");
    const loading = document.getElementById("users-loading");
    body.innerHTML = "";
    empty.classList.add("hidden");
    loading.classList.remove("hidden");
    try {
      let url = `/users?page=${page}&limit=20&search=${encodeURIComponent(search)}`;
      if (filterRole) url += `&role=${filterRole}`;
      if (filterStatus) url += `&status=${filterStatus}`;
      const data = await apiFetch(url);
      loading.classList.add("hidden");
      const items = data.items ?? data ?? [];
      const total = data.total ?? items.length;
      totalPages = Math.max(1, Math.ceil(total / 20));
      document.getElementById("page-info").textContent = `Página ${page} de ${totalPages}`;
      document.getElementById("btn-prev").disabled = page <= 1;
      document.getElementById("btn-next").disabled = page >= totalPages;
      if (items.length === 0) { empty.classList.remove("hidden"); return; }

      items.forEach(u => {
        const tr = document.createElement("tr");
        tr.className = "hover:bg-base-800/30 transition-colors";
        const status = u.status ?? (u.active === false ? "DISABLED" : "ACTIVE");
        const badgeCls = STATUS_BADGES[status] ?? STATUS_BADGES.ACTIVE;
        const userRoles = Array.isArray(u.roles) ? u.roles.map(r => r.toUpperCase()) : [];
        const rolesDisplay = userRoles.map(r => {
          const map = { ADMIN: "Admin", RECEPTIONIST: "Recep.", BARBER: "Barbero", CUSTOMER: "Cliente" };
          return `<span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium bg-base-700/60 text-base-400">${map[r] ?? r}</span>`;
        }).join(" ");
        const isActive = status !== "DISABLED";
        tr.innerHTML = `
          <td class="px-4 py-3">
            <div class="flex items-center gap-2">
              <div class="size-7 rounded-full bg-accent-900/40 flex items-center justify-center text-accent-400 text-xs font-semibold shrink-0">${u.fullName[0].toUpperCase()}</div>
              <span class="text-sm text-base-100 font-medium">${u.fullName}</span>
            </div>
          </td>
          <td class="px-4 py-3 text-sm text-base-400 hidden md:table-cell">${u.email}</td>
          <td class="px-4 py-3 hidden sm:table-cell"><div class="flex flex-wrap gap-1">${rolesDisplay || "—"}</div></td>
          <td class="px-4 py-3">
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium ${badgeCls}">${STATUS_LABELS[status] ?? status}</span>
          </td>
          <td class="px-4 py-3 text-xs text-base-500 hidden lg:table-cell">${fmtDate(u.lastLoginAt ?? u.lastLogin)}</td>
          <td class="px-4 py-3 text-right">
            <div class="flex items-center justify-end gap-1.5">
              <button class="btn-roles px-2.5 py-1 text-xs rounded-md bg-base-800 text-base-100 hover:bg-base-700 border border-base-700" data-id="${u.id}" data-name="${u.fullName}" data-roles='${JSON.stringify(userRoles)}'>Roles</button>
              ${isActive
                ? `<button class="btn-disable px-2.5 py-1 text-xs rounded-md bg-red-900/20 text-red-400 border border-red-800/30 hover:bg-red-900/40" data-id="${u.id}">Deshabilitar</button>`
                : `<button class="btn-enable px-2.5 py-1 text-xs rounded-md bg-green-900/20 text-green-400 border border-green-800/30 hover:bg-green-900/40" data-id="${u.id}">Habilitar</button>`
              }
            </div>
          </td>`;
        body.appendChild(tr);
      });

      body.querySelectorAll(".btn-roles").forEach(btn => {
        btn.addEventListener("click", () => {
          document.getElementById("roles-user-id").value = btn.dataset.id;
          document.getElementById("roles-modal-user").textContent = btn.dataset.name;
          const currentRoles = JSON.parse(btn.dataset.roles);
          document.querySelectorAll(".edit-role-check").forEach(cb => {
            cb.checked = currentRoles.includes(cb.value);
          });
          document.getElementById("modal-roles").classList.remove("hidden");
        });
      });
      body.querySelectorAll(".btn-disable").forEach(btn => {
        btn.addEventListener("click", async () => {
          if (!confirm("¿Deshabilitar este usuario?")) return;
          try {
            await apiFetch(`/users/${btn.dataset.id}/disable`, { method: "PATCH" });
            window.toast("Usuario deshabilitado", "success");
            loadUsers();
          } catch (err) { window.toast(err.message ?? "Error", "error"); }
        });
      });
      body.querySelectorAll(".btn-enable").forEach(btn => {
        btn.addEventListener("click", async () => {
          try {
            await apiFetch(`/users/${btn.dataset.id}/enable`, { method: "PATCH" });
            window.toast("Usuario habilitado", "success");
            loadUsers();
          } catch (err) { window.toast(err.message ?? "Error", "error"); }
        });
      });
    } catch (err) {
      loading.classList.add("hidden");
      window.toast(err.message ?? "Error al cargar usuarios", "error");
    }
  }

  // Search & filters
  document.getElementById("btn-search").addEventListener("click", () => {
    search = document.getElementById("search-input").value.trim();
    filterRole = document.getElementById("filter-role").value;
    filterStatus = document.getElementById("filter-status").value;
    page = 1; loadUsers();
  });
  document.getElementById("search-input").addEventListener("keydown", (e) => {
    if (e.key === "Enter") {
      search = e.target.value.trim();
      filterRole = document.getElementById("filter-role").value;
      filterStatus = document.getElementById("filter-status").value;
      page = 1; loadUsers();
    }
  });

  // Pagination
  document.getElementById("btn-prev").addEventListener("click", () => { if (page > 1) { page--; loadUsers(); } });
  document.getElementById("btn-next").addEventListener("click", () => { if (page < totalPages) { page++; loadUsers(); } });

  // Modal open/close helpers
  function openCreateModal() {
    // Reset auto tab state
    document.getElementById("lookup-email").value = "";
    document.getElementById("lookup-result").classList.add("hidden");
    document.getElementById("lookup-not-found").classList.add("hidden");
    document.getElementById("lookup-user-id").value = "";
    document.getElementById("assign-submit").disabled = true;
    document.querySelectorAll(".assign-role-check").forEach(cb => cb.checked = false);
    // Reset manual tab state
    document.getElementById("u-fullname").value = "";
    document.getElementById("u-email").value = "";
    document.getElementById("u-password").value = "";
    document.querySelectorAll(".role-check").forEach(cb => cb.checked = false);
    // Show auto tab by default
    switchTab("auto");
    document.getElementById("modal-create").classList.remove("hidden");
  }

  function closeCreateModal() {
    document.getElementById("modal-create").classList.add("hidden");
  }

  function switchTab(tab) {
    const tabAuto = document.getElementById("tab-auto");
    const tabManual = document.getElementById("tab-manual");
    const panelAuto = document.getElementById("panel-auto");
    const panelManual = document.getElementById("panel-manual");
    if (tab === "auto") {
      tabAuto.classList.add("bg-base-700", "text-base-100");
      tabAuto.classList.remove("text-base-400");
      tabManual.classList.remove("bg-base-700", "text-base-100");
      tabManual.classList.add("text-base-400");
      panelAuto.classList.remove("hidden");
      panelManual.classList.add("hidden");
    } else {
      tabManual.classList.add("bg-base-700", "text-base-100");
      tabManual.classList.remove("text-base-400");
      tabAuto.classList.remove("bg-base-700", "text-base-100");
      tabAuto.classList.add("text-base-400");
      panelManual.classList.remove("hidden");
      panelAuto.classList.add("hidden");
    }
  }

  document.getElementById("btn-open-create").addEventListener("click", openCreateModal);
  document.getElementById("create-close-auto").addEventListener("click", closeCreateModal);
  document.getElementById("create-close-manual").addEventListener("click", closeCreateModal);
  document.getElementById("modal-create").addEventListener("click", (e) => {
    if (e.target === e.currentTarget) closeCreateModal();
  });

  document.getElementById("tab-auto").addEventListener("click", () => switchTab("auto"));
  document.getElementById("tab-manual").addEventListener("click", () => switchTab("manual"));

  // Lookup existing user
  document.getElementById("btn-lookup").addEventListener("click", async () => {
    const email = document.getElementById("lookup-email").value.trim();
    if (!email) { window.toast("Ingresa un email", "error"); return; }
    const result = document.getElementById("lookup-result");
    const notFound = document.getElementById("lookup-not-found");
    result.classList.add("hidden");
    notFound.classList.add("hidden");
    document.getElementById("assign-submit").disabled = true;
    try {
      const data = await apiFetch(`/users/lookup?email=${encodeURIComponent(email)}`);
      if (!data) {
        notFound.classList.remove("hidden");
        return;
      }
      document.getElementById("lookup-user-id").value = data.id;
      document.getElementById("lookup-name").textContent = data.fullName;
      document.getElementById("lookup-email-display").textContent = data.email;
      document.getElementById("lookup-avatar").textContent = data.fullName[0].toUpperCase();
      result.classList.remove("hidden");
      document.getElementById("assign-submit").disabled = false;
    } catch {
      notFound.classList.remove("hidden");
    }
  });

  document.getElementById("lookup-email").addEventListener("keydown", (e) => {
    if (e.key === "Enter") document.getElementById("btn-lookup").click();
  });

  // Assign existing user as staff
  document.getElementById("assign-submit").addEventListener("click", async () => {
    const userId = document.getElementById("lookup-user-id").value;
    const selectedRoles = Array.from(document.querySelectorAll(".assign-role-check:checked")).map(cb => cb.value);
    if (selectedRoles.length === 0) {
      window.toast("Selecciona al menos un rol", "error"); return;
    }
    try {
      await apiFetch(`/users/${userId}/assign-staff`, { method: "POST", body: JSON.stringify({ roles: selectedRoles }) });
      window.toast("Usuario vinculado a la barbería", "success");
      closeCreateModal();
      loadUsers();
    } catch (err) { window.toast(err.message ?? "Error al vincular usuario", "error"); }
  });

  // Create new user (manual)
  document.getElementById("create-submit").addEventListener("click", async () => {
    const fullName = document.getElementById("u-fullname").value.trim();
    const email = document.getElementById("u-email").value.trim();
    const password = document.getElementById("u-password").value;
    const selectedRoles = Array.from(document.querySelectorAll(".role-check:checked")).map(cb => cb.value);
    if (!fullName || !email || !password) {
      window.toast("Completa todos los campos obligatorios", "error"); return;
    }
    if (selectedRoles.length === 0) {
      window.toast("Selecciona al menos un rol", "error"); return;
    }
    try {
      await apiFetch("/users", { method: "POST", body: JSON.stringify({ fullName, email, password, roles: selectedRoles }) });
      window.toast("Usuario creado", "success");
      closeCreateModal();
      loadUsers();
    } catch (err) { window.toast(err.message ?? "Error al crear usuario", "error"); }
  });

  // Edit roles
  document.getElementById("roles-close").addEventListener("click", () => {
    document.getElementById("modal-roles").classList.add("hidden");
  });
  document.getElementById("modal-roles").addEventListener("click", (e) => {
    if (e.target === e.currentTarget) e.currentTarget.classList.add("hidden");
  });
  document.getElementById("roles-submit").addEventListener("click", async () => {
    const id = document.getElementById("roles-user-id").value;
    const selectedRoles = Array.from(document.querySelectorAll(".edit-role-check:checked")).map(cb => cb.value);
    if (selectedRoles.length === 0) {
      window.toast("Selecciona al menos un rol", "error"); return;
    }
    try {
      await apiFetch(`/users/${id}/roles`, { method: "PATCH", body: JSON.stringify({ roles: selectedRoles }) });
      window.toast("Roles actualizados", "success");
      document.getElementById("modal-roles").classList.add("hidden");
      loadUsers();
    } catch (err) { window.toast(err.message ?? "Error al actualizar roles", "error"); }
  });

  loadUsers();
</script>
