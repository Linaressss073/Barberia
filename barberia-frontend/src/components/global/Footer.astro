---
import Logo from "@/components/assets/Logo.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";

const sections = [
  {
    title: "Plataforma",
    links: [
      { name: "Inicio", href: "/" },
      { name: "Funciones", href: "/#features" },
      { name: "Precios", href: "/#pricing" },
      { name: "FAQ", href: "/#faq" },
    ],
  },
  {
    title: "Cuenta",
    links: [
      { name: "Crear cuenta", href: "/signup" },
      { name: "Iniciar sesión", href: "/login" },
      { name: "Panel", href: "/dashboard" },
    ],
  },
  {
    title: "Legal",
    links: [
      { name: "Términos de uso", href: "/terms" },
      { name: "Privacidad", href: "/terms" },
    ],
  },
  {
    title: "Soporte",
    links: [
      { name: "soporte@barberia.app", href: "mailto:soporte@barberia.app" },
    ],
  },
];

const currentYear = new Date().getFullYear();
---

<footer class="bg-base-950 border-t border-base-800">
  <Wrapper variant="standard" class="py-12">
    <div class="grid grid-cols-2 lg:grid-cols-4 items-start gap-x-8 gap-y-24">
      <a href="/">
        <Logo class="text-accent-500" />
      </a>
      <div
        class="grid grid-cols-2 md:grid-cols-4 gap-y-8 gap-x-4 lg:col-span-3"
      >
        {
          sections.map(({ title, links }) => (
            <div>
              <Text
                tag="h3"
                variant="textSM"
                class="text-base-300 font-medium uppercase tracking-widest"
              >
                {title}
              </Text>
              <ul role="list" class="mt-4 space-y-1">
                {links.map(({ name, href }) => (
                  <li>
                    <a
                      href={href}
                      class="text-sm font-medium text-base-500 hover:text-accent-400 transition-colors duration-200"
                    >
                      {name}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </div>
    <div class="border-t pt-6 border-base-800 mt-8">
      <p class="text-xs text-base-600">
        © {currentYear} Barbería. Todos los derechos reservados.
      </p>
    </div>
  </Wrapper>
</footer>
