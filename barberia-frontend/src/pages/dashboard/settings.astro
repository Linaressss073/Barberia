---
import DashboardLayout from "@/layouts/DashboardLayout.astro";
---
<DashboardLayout title="Configuración" section="settings">

  <div class="max-w-xl space-y-8">

    <section class="bg-base-900 border border-base-800 rounded-xl p-6 space-y-4">
      <h2 class="text-base font-semibold text-base-100">Perfil</h2>
      <div>
        <label class="text-xs uppercase tracking-widest text-base-500">Nombre completo</label>
        <input id="pf-name" type="text"
          class="mt-1 w-full bg-base-900 ring-1 ring-base-700 text-base-100 rounded-lg px-3 py-2 text-sm focus:ring-accent-500 focus:ring-2 focus:outline-none" />
      </div>
      <div>
        <label class="text-xs uppercase tracking-widest text-base-500">Correo</label>
        <input id="pf-email" type="email" readonly
          class="mt-1 w-full bg-base-950/80 ring-1 ring-base-800 text-base-400 rounded-lg px-3 py-2 text-sm cursor-not-allowed" />
      </div>
      <button id="pf-save" type="button"
        class="px-4 py-2 text-sm font-medium rounded-lg bg-accent-500 text-base-950 hover:bg-accent-400 transition-colors">
        Guardar perfil
      </button>
    </section>

    <section class="bg-base-900 border border-base-800 rounded-xl p-6 space-y-4">
      <h2 class="text-base font-semibold text-base-100">Contraseña</h2>
      <div>
        <label class="text-xs uppercase tracking-widest text-base-500">Contraseña actual</label>
        <input id="pw-current" type="password" autocomplete="current-password"
          class="mt-1 w-full bg-base-900 ring-1 ring-base-700 text-base-100 rounded-lg px-3 py-2 text-sm focus:ring-accent-500 focus:ring-2 focus:outline-none" />
      </div>
      <div>
        <label class="text-xs uppercase tracking-widest text-base-500">Nueva contraseña</label>
        <input id="pw-new" type="password" autocomplete="new-password"
          class="mt-1 w-full bg-base-900 ring-1 ring-base-700 text-base-100 rounded-lg px-3 py-2 text-sm focus:ring-accent-500 focus:ring-2 focus:outline-none" />
      </div>
      <div>
        <label class="text-xs uppercase tracking-widest text-base-500">Confirmar nueva contraseña</label>
        <input id="pw-confirm" type="password" autocomplete="new-password"
          class="mt-1 w-full bg-base-900 ring-1 ring-base-700 text-base-100 rounded-lg px-3 py-2 text-sm focus:ring-accent-500 focus:ring-2 focus:outline-none" />
      </div>
      <button id="pw-save" type="button"
        class="px-4 py-2 text-sm font-medium rounded-lg bg-base-800 text-base-100 border border-base-700 hover:bg-base-700 transition-colors">
        Actualizar contraseña
      </button>
    </section>

    <section id="sec-plan" class="hidden bg-base-900 border border-base-800 rounded-xl p-6 space-y-3">
      <h2 class="text-base font-semibold text-base-100">Plan del negocio</h2>
      <p id="plan-summary" class="text-sm text-base-400"></p>
      <p id="plan-trial" class="text-sm text-base-500"></p>
      <p id="plan-usage" class="text-sm text-base-300"></p>
    </section>

  </div>
</DashboardLayout>

<script>
  import { getUser, saveSession, getAccessToken, getRefreshToken } from "@/lib/auth";
  import { apiFetch } from "@/lib/api";

  const user = getUser()!;
  const roles = user.roles.map((r) => r.toUpperCase());

  document.getElementById("pf-name").value = user.fullName;
  document.getElementById("pf-email").value = user.email;

  document.getElementById("pf-save").addEventListener("click", async () => {
    const fullName = document.getElementById("pf-name").value.trim();
    if (!fullName) {
      window.toast("Indica un nombre", "error");
      return;
    }
    try {
      const data = await apiFetch("/users/me", {
        method: "PATCH",
        body: JSON.stringify({ fullName }),
      });
      const tok = getAccessToken();
      const rt = getRefreshToken();
      if (tok && rt) {
        saveSession(
          {
            id: data.id,
            email: data.email,
            fullName: data.fullName,
            roles: data.roles.map((r: string) => r.toUpperCase()),
            tenantId: data.tenantId ?? null,
          },
          tok,
          rt,
        );
      }
      document.getElementById("sidebar-name").textContent = data.fullName;
      window.toast("Perfil actualizado", "success");
    } catch (e) {
      window.toast(e.message ?? "Error", "error");
    }
  });

  document.getElementById("pw-save").addEventListener("click", async () => {
    const currentPassword = document.getElementById("pw-current").value;
    const newPassword = document.getElementById("pw-new").value;
    const confirm = document.getElementById("pw-confirm").value;
    if (!newPassword) {
      window.toast("Indica la nueva contraseña", "error");
      return;
    }
    if (newPassword !== confirm) {
      window.toast("Las contraseñas nuevas no coinciden", "error");
      return;
    }
    try {
      await apiFetch("/users/me", {
        method: "PATCH",
        body: JSON.stringify({ currentPassword, newPassword }),
      });
      document.getElementById("pw-current").value = "";
      document.getElementById("pw-new").value = "";
      document.getElementById("pw-confirm").value = "";
      window.toast("Contraseña actualizada", "success");
    } catch (e) {
      window.toast(e.message ?? "Error", "error");
    }
  });

  if (roles.includes("ADMIN")) {
    document.getElementById("sec-plan").classList.remove("hidden");
    Promise.all([
      apiFetch("/tenants/me").catch(() => null),
      apiFetch("/barbers?page=1&limit=500&onlyActive=true").catch(() => ({ total: 0 })),
    ]).then(([tenant, barbers]) => {
      const labels: Record<string, string> = {
        TRIAL: "Prueba",
        BASIC: "Básico",
        PROFESSIONAL: "Profesional",
        ENTERPRISE: "Enterprise",
      };
      if (!tenant) {
        document.getElementById("plan-summary").textContent = "No hay información de plan (sin tenant).";
        return;
      }
      document.getElementById("plan-summary").textContent =
        `Plan actual: ${labels[tenant.plan] ?? tenant.plan}`;
      if (tenant.trialEndsAt && tenant.plan === "TRIAL") {
        const end = new Date(tenant.trialEndsAt);
        const days = Math.max(0, Math.ceil((end.getTime() - Date.now()) / 86400000));
        document.getElementById("plan-trial").textContent =
          `Período de prueba: ${days} día${days !== 1 ? "s" : ""} restantes (hasta ${end.toLocaleDateString("es-CO")}).`;
      } else {
        document.getElementById("plan-trial").textContent = "";
      }
      const n = barbers?.total ?? barbers?.items?.length ?? 0;
      const max = tenant.maxBarbers;
      document.getElementById("plan-usage").textContent =
        max === -1 ? `Barberos activos en uso: ${n} (sin límite).` : `Barberos activos en uso: ${n} de ${max}.`;
    });
  }
</script>
