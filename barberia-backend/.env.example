# ===== App =====
NODE_ENV=development
PORT=3000
APP_NAME=barberia-backend
APP_VERSION=0.1.0
GLOBAL_PREFIX=api/v1
# En producción (Render): solo el origen de Vercel.
# En local puedes separar múltiples orígenes con coma.
FRONTEND_URL=https://barberia-hgtl.vercel.app

# ===== Database (MongoDB Atlas) =====
# Obtener desde MongoDB Atlas > Connect > Drivers
DATABASE_URL=mongodb+srv://user:password@cluster.mongodb.net/barberia?retryWrites=true&w=majority

# ===== JWT =====
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_ACCESS_TTL=900s
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_REFRESH_TTL=7d

# ===== Bcrypt =====
BCRYPT_SALT_ROUNDS=12

# ===== Throttler =====
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100

# ===== Integraciones (futuro) =====
EMAIL_API_KEY=
WHATSAPP_API_KEY=
