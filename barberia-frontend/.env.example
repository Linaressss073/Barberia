# Copiar a .env y ajustar. Solo variables PUBLIC_* se exponen al cliente.

# Backend Nest (sin path; el cliente añade /api/v1 en código).
PUBLIC_API_URL=http://localhost:3000

# URL pública del frontend (producción en Vercel). Usada en build para sitemap y site.
PUBLIC_SITE_URL=https://yoursite.com
