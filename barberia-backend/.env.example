# ===== App =====
NODE_ENV=development
PORT=3000
APP_NAME=barberia-backend
APP_VERSION=0.1.0
GLOBAL_PREFIX=api/v1
FRONTEND_URL=http://localhost:3001

# ===== Database (Render PostgreSQL) =====
# En Render usar la "Internal Database URL" para servicios en la misma region.
DATABASE_URL=postgresql://user:password@host:5432/barberia?sslmode=require
DATABASE_SSL=true
DATABASE_LOGGING=false
DATABASE_POOL_MAX=10

# ===== JWT =====
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_ACCESS_TTL=900s
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_REFRESH_TTL=7d

# ===== Bcrypt =====
BCRYPT_SALT_ROUNDS=12

# ===== Throttler =====
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100

# ===== Integraciones (futuro) =====
EMAIL_API_KEY=
WHATSAPP_API_KEY=
