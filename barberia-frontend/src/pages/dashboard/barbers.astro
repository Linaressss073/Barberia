---
import DashboardLayout from "@/layouts/DashboardLayout.astro";
---
<DashboardLayout title="Barberos" section="barbers">

  <div class="space-y-5">
    <!-- Header -->
    <div class="flex items-center justify-between">
      <div class="flex gap-2">
        <input id="search-input" type="text" placeholder="Buscar barbero…"
          class="bg-base-900 ring-1 ring-base-700 text-base-100 focus:ring-accent-500 focus:ring-2 focus:outline-none rounded-lg px-3 py-2 text-sm w-48 sm:w-64" />
        <button id="btn-search" class="px-4 py-2 text-sm rounded-lg bg-base-800 text-base-100 hover:bg-base-700 border border-base-700">Buscar</button>
      </div>
      <button id="btn-open-create" class="hidden px-4 py-2 text-sm font-medium rounded-lg bg-accent-500 text-base-950 hover:bg-accent-400">+ Nuevo Barbero</button>
    </div>

    <!-- Table -->
    <div class="bg-base-900 border border-base-800 rounded-xl overflow-hidden">
      <table class="w-full">
        <thead>
          <tr class="bg-base-800/60">
            <th class="px-4 py-3 text-left text-xs font-medium text-base-500 uppercase tracking-widest">Nombre</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-base-500 uppercase tracking-widest hidden sm:table-cell">Especialidad</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-base-500 uppercase tracking-widest hidden md:table-cell">Comisión</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-base-500 uppercase tracking-widest">Estado</th>
            <th class="px-4 py-3 text-right text-xs font-medium text-base-500 uppercase tracking-widest">Acciones</th>
          </tr>
        </thead>
        <tbody id="barbers-body" class="divide-y divide-base-800"></tbody>
      </table>
      <div id="barbers-empty" class="hidden p-12 text-center text-base-500 text-sm">No hay barberos registrados.</div>
      <div id="barbers-loading" class="p-8 text-center text-base-500 text-sm">Cargando barberos…</div>
    </div>

    <!-- Pagination -->
    <div class="flex items-center justify-between">
      <button id="btn-prev" disabled class="px-4 py-2 text-sm rounded-lg bg-base-800 text-base-100 hover:bg-base-700 border border-base-700 disabled:opacity-40 disabled:cursor-not-allowed">← Anterior</button>
      <span id="page-info" class="text-sm text-base-500">Página 1</span>
      <button id="btn-next" disabled class="px-4 py-2 text-sm rounded-lg bg-base-800 text-base-100 hover:bg-base-700 border border-base-700 disabled:opacity-40 disabled:cursor-not-allowed">Siguiente →</button>
    </div>
  </div>

  <!-- Create barber modal -->
  <div id="modal-create" class="fixed inset-0 z-50 flex items-center justify-center bg-black/60 hidden">
    <div class="bg-base-900 border border-base-800 rounded-2xl p-6 w-full max-w-lg mx-4 shadow-2xl">
      <h3 class="text-base-100 font-semibold text-lg mb-5">Nuevo Barbero</h3>
      <div class="space-y-4">
        <div>
          <label class="text-xs uppercase tracking-widest text-base-500">UUID de usuario *</label>
          <input id="b-userid" type="text" placeholder="UUID del usuario en el sistema"
            class="mt-1 bg-base-900 ring-1 ring-base-700 text-base-100 focus:ring-accent-500 focus:ring-2 focus:outline-none rounded-lg px-3 py-2 text-sm w-full" />
        </div>
        <div>
          <label class="text-xs uppercase tracking-widest text-base-500">Nombre a mostrar *</label>
          <input id="b-displayname" type="text" placeholder="Nombre del barbero"
            class="mt-1 bg-base-900 ring-1 ring-base-700 text-base-100 focus:ring-accent-500 focus:ring-2 focus:outline-none rounded-lg px-3 py-2 text-sm w-full" />
        </div>
        <div>
          <label class="text-xs uppercase tracking-widest text-base-500">Especialidad</label>
          <input id="b-specialty" type="text" placeholder="Ej: Fade, Clásico, Diseño"
            class="mt-1 bg-base-900 ring-1 ring-base-700 text-base-100 focus:ring-accent-500 focus:ring-2 focus:outline-none rounded-lg px-3 py-2 text-sm w-full" />
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="text-xs uppercase tracking-widest text-base-500">Fecha contratación *</label>
            <input id="b-hiredate" type="date"
              class="mt-1 bg-base-900 ring-1 ring-base-700 text-base-100 focus:ring-accent-500 focus:ring-2 focus:outline-none rounded-lg px-3 py-2 text-sm w-full" />
          </div>
          <div>
            <label class="text-xs uppercase tracking-widest text-base-500">Comisión % *</label>
            <input id="b-commission" type="number" min="0" max="100" placeholder="20"
              class="mt-1 bg-base-900 ring-1 ring-base-700 text-base-100 focus:ring-accent-500 focus:ring-2 focus:outline-none rounded-lg px-3 py-2 text-sm w-full" />
          </div>
        </div>
      </div>
      <div class="flex justify-end gap-2 mt-6">
        <button id="create-close" class="px-4 py-2 text-sm rounded-lg bg-base-800 text-base-100 hover:bg-base-700 border border-base-700">Cancelar</button>
        <button id="create-submit" class="px-5 py-2 text-sm font-medium rounded-lg bg-accent-500 text-base-950 hover:bg-accent-400">Crear Barbero</button>
      </div>
    </div>
  </div>

  <!-- Edit barber modal -->
  <div id="modal-edit" class="fixed inset-0 z-50 flex items-center justify-center bg-black/60 hidden">
    <div class="bg-base-900 border border-base-800 rounded-2xl p-6 w-full max-w-lg mx-4 shadow-2xl">
      <h3 class="text-base-100 font-semibold text-lg mb-5">Editar Barbero</h3>
      <input type="hidden" id="edit-id" />
      <div class="space-y-4">
        <div>
          <label class="text-xs uppercase tracking-widest text-base-500">Nombre a mostrar</label>
          <input id="edit-displayname" type="text"
            class="mt-1 bg-base-900 ring-1 ring-base-700 text-base-100 focus:ring-accent-500 focus:ring-2 focus:outline-none rounded-lg px-3 py-2 text-sm w-full" />
        </div>
        <div>
          <label class="text-xs uppercase tracking-widest text-base-500">Especialidad</label>
          <input id="edit-specialty" type="text"
            class="mt-1 bg-base-900 ring-1 ring-base-700 text-base-100 focus:ring-accent-500 focus:ring-2 focus:outline-none rounded-lg px-3 py-2 text-sm w-full" />
        </div>
        <div>
          <label class="text-xs uppercase tracking-widest text-base-500">Comisión %</label>
          <input id="edit-commission" type="number" min="0" max="100"
            class="mt-1 bg-base-900 ring-1 ring-base-700 text-base-100 focus:ring-accent-500 focus:ring-2 focus:outline-none rounded-lg px-3 py-2 text-sm w-full" />
        </div>
        <div class="flex items-center gap-3">
          <input id="edit-active" type="checkbox" class="rounded" />
          <label class="text-sm text-base-300">Activo</label>
        </div>
      </div>
      <div class="flex justify-end gap-2 mt-6">
        <button id="edit-close" class="px-4 py-2 text-sm rounded-lg bg-base-800 text-base-100 hover:bg-base-700 border border-base-700">Cancelar</button>
        <button id="edit-submit" class="px-5 py-2 text-sm font-medium rounded-lg bg-accent-500 text-base-950 hover:bg-accent-400">Guardar</button>
      </div>
    </div>
  </div>

  <!-- Schedules modal -->
  <div id="modal-schedules" class="fixed inset-0 z-50 flex items-center justify-center bg-black/60 hidden">
    <div class="bg-base-900 border border-base-800 rounded-2xl p-6 w-full max-w-xl mx-4 shadow-2xl max-h-[90vh] overflow-y-auto">
      <h3 class="text-base-100 font-semibold text-lg mb-5">Horarios de trabajo</h3>
      <input type="hidden" id="sched-barber-id" />
      <div id="sched-grid" class="space-y-3"></div>
      <div class="flex justify-end gap-2 mt-6">
        <button id="sched-close" class="px-4 py-2 text-sm rounded-lg bg-base-800 text-base-100 hover:bg-base-700 border border-base-700">Cancelar</button>
        <button id="sched-submit" class="px-5 py-2 text-sm font-medium rounded-lg bg-accent-500 text-base-950 hover:bg-accent-400">Guardar Horarios</button>
      </div>
    </div>
  </div>

</DashboardLayout>

<script>
  import { getUser } from "@/lib/auth";
  import { apiFetch } from "@/lib/api";

  const user = getUser();
  const roles = user.roles.map(r => r.toUpperCase());
  if (!roles.some(r => ["ADMIN","RECEPTIONIST"].includes(r))) {
    window.location.href = "/dashboard/";
    throw new Error("redirect");
  }
  const isAdmin = roles.includes("ADMIN");

  if (isAdmin) {
    document.getElementById("btn-open-create").classList.remove("hidden");
  }

  const WEEKDAYS = ["Dom","Lun","Mar","Mié","Jue","Vie","Sáb"];
  let page = 1;
  let totalPages = 1;
  let search = "";

  async function loadBarbers() {
    const body = document.getElementById("barbers-body");
    const empty = document.getElementById("barbers-empty");
    const loading = document.getElementById("barbers-loading");
    body.innerHTML = "";
    empty.classList.add("hidden");
    loading.classList.remove("hidden");
    try {
      const data = await apiFetch(`/barbers?page=${page}&limit=20&search=${encodeURIComponent(search)}`);
      loading.classList.add("hidden");
      const items = data.items ?? data ?? [];
      const total = data.total ?? items.length;
      totalPages = Math.max(1, Math.ceil(total / 20));
      document.getElementById("page-info").textContent = `Página ${page} de ${totalPages}`;
      document.getElementById("btn-prev").disabled = page <= 1;
      document.getElementById("btn-next").disabled = page >= totalPages;
      if (items.length === 0) { empty.classList.remove("hidden"); return; }
      items.forEach(b => {
        const tr = document.createElement("tr");
        tr.className = "hover:bg-base-800/30 transition-colors";
        const activeBadge = b.active
          ? `<span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-900/40 text-green-400 border border-green-800/40">Activo</span>`
          : `<span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-base-700/40 text-base-500 border border-base-700/40">Inactivo</span>`;
        const adminActions = isAdmin ? `
          <button class="btn-edit px-2.5 py-1 text-xs rounded-md bg-base-800 text-base-100 hover:bg-base-700 border border-base-700" data-id="${b.id}" data-name="${b.displayName}" data-specialty="${b.specialty ?? ''}" data-commission="${b.commissionPct}" data-active="${b.active}">Editar</button>
          <button class="btn-sched px-2.5 py-1 text-xs rounded-md bg-base-800 text-base-100 hover:bg-base-700 border border-base-700" data-id="${b.id}">Horarios</button>` : "";
        tr.innerHTML = `
          <td class="px-4 py-3">
            <div class="flex items-center gap-2">
              <div class="size-8 rounded-full bg-accent-900/50 flex items-center justify-center text-accent-400 font-semibold text-xs shrink-0">${b.displayName[0].toUpperCase()}</div>
              <span class="text-sm text-base-100 font-medium">${b.displayName}</span>
            </div>
          </td>
          <td class="px-4 py-3 text-sm text-base-400 hidden sm:table-cell">${b.specialty ?? "—"}</td>
          <td class="px-4 py-3 text-sm text-base-400 hidden md:table-cell">${b.commissionPct ?? 0}%</td>
          <td class="px-4 py-3">${activeBadge}</td>
          <td class="px-4 py-3 text-right">
            <div class="flex items-center justify-end gap-1.5">${adminActions}</div>
          </td>`;
        body.appendChild(tr);
      });

      if (isAdmin) {
        body.querySelectorAll(".btn-edit").forEach(btn => {
          btn.addEventListener("click", () => {
            document.getElementById("edit-id").value = btn.dataset.id;
            document.getElementById("edit-displayname").value = btn.dataset.name;
            document.getElementById("edit-specialty").value = btn.dataset.specialty;
            document.getElementById("edit-commission").value = btn.dataset.commission;
            document.getElementById("edit-active").checked = btn.dataset.active === "true";
            document.getElementById("modal-edit").classList.remove("hidden");
          });
        });
        body.querySelectorAll(".btn-sched").forEach(btn => {
          btn.addEventListener("click", () => openSchedules(btn.dataset.id));
        });
      }
    } catch (err) {
      loading.classList.add("hidden");
      window.toast(err.message ?? "Error al cargar barberos", "error");
    }
  }

  function openSchedules(barberId) {
    document.getElementById("sched-barber-id").value = barberId;
    const grid = document.getElementById("sched-grid");
    grid.innerHTML = "";
    WEEKDAYS.forEach((day, idx) => {
      const row = document.createElement("div");
      row.className = "flex items-center gap-3 p-3 rounded-lg bg-base-800/40 border border-base-700/50";
      row.innerHTML = `
        <input type="checkbox" id="day-${idx}" class="rounded" />
        <label for="day-${idx}" class="text-sm text-base-300 w-8 shrink-0">${day}</label>
        <div class="flex items-center gap-2 flex-1">
          <input type="time" id="start-${idx}" value="09:00"
            class="bg-base-900 ring-1 ring-base-700 text-base-100 focus:ring-accent-500 focus:ring-2 focus:outline-none rounded-lg px-2 py-1.5 text-sm flex-1" />
          <span class="text-base-500 text-xs">a</span>
          <input type="time" id="end-${idx}" value="18:00"
            class="bg-base-900 ring-1 ring-base-700 text-base-100 focus:ring-accent-500 focus:ring-2 focus:outline-none rounded-lg px-2 py-1.5 text-sm flex-1" />
        </div>`;
      grid.appendChild(row);
    });
    document.getElementById("modal-schedules").classList.remove("hidden");
  }

  // Search
  document.getElementById("btn-search").addEventListener("click", () => {
    search = document.getElementById("search-input").value.trim();
    page = 1; loadBarbers();
  });
  document.getElementById("search-input").addEventListener("keydown", (e) => {
    if (e.key === "Enter") { search = e.target.value.trim(); page = 1; loadBarbers(); }
  });

  // Pagination
  document.getElementById("btn-prev").addEventListener("click", () => { if (page > 1) { page--; loadBarbers(); } });
  document.getElementById("btn-next").addEventListener("click", () => { if (page < totalPages) { page++; loadBarbers(); } });

  // Create
  document.getElementById("btn-open-create").addEventListener("click", () => {
    document.getElementById("modal-create").classList.remove("hidden");
  });
  document.getElementById("create-close").addEventListener("click", () => {
    document.getElementById("modal-create").classList.add("hidden");
  });
  document.getElementById("modal-create").addEventListener("click", (e) => {
    if (e.target === e.currentTarget) e.currentTarget.classList.add("hidden");
  });
  document.getElementById("create-submit").addEventListener("click", async () => {
    const userId = document.getElementById("b-userid").value.trim();
    const displayName = document.getElementById("b-displayname").value.trim();
    const specialty = document.getElementById("b-specialty").value.trim();
    const hireDate = document.getElementById("b-hiredate").value;
    const commissionPct = parseFloat(document.getElementById("b-commission").value);
    if (!userId || !displayName || !hireDate || isNaN(commissionPct)) {
      window.toast("Completa todos los campos obligatorios", "error"); return;
    }
    const payload = { userId, displayName, hireDate, commissionPct };
    if (specialty) payload.specialty = specialty;
    try {
      await apiFetch("/barbers", { method: "POST", body: JSON.stringify(payload) });
      window.toast("Barbero creado", "success");
      document.getElementById("modal-create").classList.add("hidden");
      loadBarbers();
    } catch (err) { window.toast(err.message ?? "Error al crear barbero", "error"); }
  });

  // Edit
  document.getElementById("edit-close").addEventListener("click", () => {
    document.getElementById("modal-edit").classList.add("hidden");
  });
  document.getElementById("modal-edit").addEventListener("click", (e) => {
    if (e.target === e.currentTarget) e.currentTarget.classList.add("hidden");
  });
  document.getElementById("edit-submit").addEventListener("click", async () => {
    const id = document.getElementById("edit-id").value;
    const payload = {};
    const dn = document.getElementById("edit-displayname").value.trim();
    if (dn) payload.displayName = dn;
    const sp = document.getElementById("edit-specialty").value.trim();
    if (sp) payload.specialty = sp;
    const cp = parseFloat(document.getElementById("edit-commission").value);
    if (!isNaN(cp)) payload.commissionPct = cp;
    payload.active = document.getElementById("edit-active").checked;
    try {
      await apiFetch(`/barbers/${id}`, { method: "PATCH", body: JSON.stringify(payload) });
      window.toast("Barbero actualizado", "success");
      document.getElementById("modal-edit").classList.add("hidden");
      loadBarbers();
    } catch (err) { window.toast(err.message ?? "Error al actualizar", "error"); }
  });

  // Schedules
  document.getElementById("sched-close").addEventListener("click", () => {
    document.getElementById("modal-schedules").classList.add("hidden");
  });
  document.getElementById("modal-schedules").addEventListener("click", (e) => {
    if (e.target === e.currentTarget) e.currentTarget.classList.add("hidden");
  });
  document.getElementById("sched-submit").addEventListener("click", async () => {
    const barberId = document.getElementById("sched-barber-id").value;
    const schedules = [];
    for (let i = 0; i < 7; i++) {
      const active = document.getElementById(`day-${i}`).checked;
      if (active) {
        schedules.push({
          weekday: i,
          startTime: document.getElementById(`start-${i}`).value,
          endTime: document.getElementById(`end-${i}`).value,
        });
      }
    }
    try {
      await apiFetch(`/barbers/${barberId}/schedules`, { method: "POST", body: JSON.stringify({ schedules }) });
      window.toast("Horarios guardados", "success");
      document.getElementById("modal-schedules").classList.add("hidden");
    } catch (err) { window.toast(err.message ?? "Error al guardar horarios", "error"); }
  });

  loadBarbers();
</script>
