# Copiar a .env y ajustar. Solo variables PUBLIC_* se exponen al cliente.
# En Vercel: configura estas variables en Project Settings → Environment Variables.

# Backend Nest en Render (sin path; el cliente añade /api/v1 en código).
PUBLIC_API_URL=https://barberia-1yoo.onrender.com

# URL pública del frontend (producción en Vercel). Usada para sitemap y meta canónico.
PUBLIC_SITE_URL=https://barberia-hgtl.vercel.app
