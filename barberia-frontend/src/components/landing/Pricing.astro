---
import Text from "@/components/fundations/elements/Text.astro";
import Button from "@/components/fundations/elements/Button.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import Check from "@/components/fundations/icons/Check.astro";

const pricingTiers = [
  {
    name: "Básico",
    subtitle: "Para barberías pequeñas",
    description:
      "Todo lo esencial para digitalizar tu barbería y empezar a recibir citas online.",
    monthlyPrice: "$29.00",
    annualPrice: "$19.00",
    features: [
      "Hasta 3 barberos activos",
      "Citas y agenda online",
      "Base de clientes ilimitada",
      "Registro de ventas y pagos",
      "Panel de administración",
      "Soporte por email",
    ],
    cta: "Comenzar con Básico",
    buttonVariant: "muted",
    isPopular: false,
    bgClass: "bg-base-900 border-base-800",
    innerClass: "bg-base-800/50",
    textClass: "text-base-100",
    priceClass: "text-base-50",
    descClass: "text-base-400",
  },
  {
    name: "Profesional",
    subtitle: "Para negocios que crecen",
    description:
      "Automatización, inventario y notificaciones para equipos de barbería en expansión.",
    monthlyPrice: "$59.00",
    annualPrice: "$45.00",
    features: [
      "Hasta 10 barberos activos",
      "Todo lo del plan Básico",
      "Control de inventario y stock",
      "Reportes avanzados y comisiones",
      "Notificaciones email y WhatsApp",
      "Programa de lealtad para clientes",
    ],
    cta: "Ir a Profesional",
    buttonVariant: "default",
    isPopular: true,
    bgClass: "bg-base-900 border-accent-700/50",
    innerClass: "bg-base-800",
    textClass: "text-base-50",
    priceClass: "text-accent-400",
    descClass: "text-base-400",
  },
  {
    name: "Enterprise",
    subtitle: "Para cadenas y equipos grandes",
    description:
      "Sin límites, múltiples sucursales y soporte dedicado para operaciones complejas.",
    monthlyPrice: "$99.00",
    annualPrice: "$79.00",
    features: [
      "Barberos y sedes ilimitadas",
      "Todo lo del plan Profesional",
      "Múltiples sucursales",
      "API y webhooks",
      "Soporte prioritario 24/7",
      "Onboarding personalizado",
    ],
    cta: "Hablar con ventas",
    buttonVariant: "muted",
    isPopular: false,
    bgClass: "bg-base-900 border-base-800",
    innerClass: "bg-base-800/50",
    textClass: "text-base-100",
    priceClass: "text-base-50",
    descClass: "text-base-400",
  },
];
---

<section id="pricing" class="bg-base-900 border-y border-base-800">
  <Wrapper variant="standard" class="py-20">
    <div class="max-w-xl text-center mx-auto">
      <Text
        tag="span"
        variant="textSM"
        class="leading-normal font-medium uppercase tracking-widest text-accent-500"
      >
        Precios
      </Text>
      <Text
        tag="h2"
        variant="displayMD"
        class="tracking-tight mt-4 font-semibold text-base-50 font-display"
      >
        Planes para cada etapa de tu negocio
      </Text>
      <Text
        tag="p"
        variant="textBase"
        class="mt-4 text-base-400 font-medium text-balance"
      >
        Empieza gratis 14 días y escala cuando necesites más funciones.
      </Text>
      <div
        aria-labelledby="pricing-toggle"
        class="w-full relative mt-8 ring-1 ring-base-700 ring-offset-2 ring-offset-base-900 bg-base-800 overflow-hidden justify-center gap-4 mx-auto lg:mx-0 inline-flex p-1 rounded-md max-w-52 shadow z-0"
      >
        <div
          id="pricing-indicator"
          class="absolute inset-0 bg-accent-600 rounded-md transition-transform duration-200 ease-in-out w-1/2 translate-x-0"
        >
        </div>
        <button
          id="monthly-pricing-button"
          class="relative flex items-center justify-center w-full px-2 h-6 text-xs font-medium focus:outline-none transition-colors duration-300 z-10 text-base-950"
          type="button"
          aria-pressed="true"
        >
          Mensual
        </button>
        <button
          id="annual-pricing-button"
          class="relative flex items-center justify-center w-full px-2 h-6 text-xs font-medium focus:outline-none transition-colors duration-300 z-10 text-base-400 hover:text-accent-400"
          type="button"
          aria-pressed="false"
        >
          Anual
        </button>
      </div>
    </div>
    <div
      class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3 mt-12 mx-auto"
    >
      {
        pricingTiers.map((tier, index) => (
          <div
            class={`flex flex-col h-full p-1 lg:py-1 rounded-3xl border ${tier.bgClass}`}
          >
            <div
              class={`p-8 ${tier.innerClass} rounded-[1.3rem] flex flex-col justify-between`}
            >
              <div>
                <div class="flex items-start justify-between w-full">
                  <div>
                    <Text
                      tag="h3"
                      variant="textBase"
                      class={`font-medium font-display ${tier.textClass}`}
                    >
                      {tier.name}
                    </Text>
                    <Text tag="p" variant="textSM" class={`${tier.descClass}`}>
                      {tier.subtitle}
                    </Text>
                  </div>
                  {tier.isPopular && (
                    <span class="inline-flex items-center font-medium relative text-base-950 bg-accent-500 px-2.5 py-1 text-xs rounded-md">
                      Popular
                    </span>
                  )}
                </div>
                <Text
                  tag="p"
                  variant="textSM"
                  class={`mt-4 ${tier.descClass}`}
                >
                  {tier.description}
                </Text>
                <Button
                  variant={tier.buttonVariant}
                  size="base"
                  class="w-full mt-12"
                  isLink
                  href="/signup"
                >
                  {tier.cta}
                </Button>
              </div>
            </div>
            <div class="p-8 flex flex-col">
              <Text
                tag="p"
                variant="displayMD"
                class={`font-medium flex items-baseline font-display ${tier.priceClass}`}
              >
                <span
                  id={`price-amount-${index}`}
                  data-monthly={tier.monthlyPrice}
                  data-annual={tier.annualPrice}
                >
                  {tier.monthlyPrice}
                </span>
                <span
                  class="text-sm font-normal tracking-normal text-base-500"
                >
                  <span id={`billing-monthly-${index}`}>/mes</span>
                  <span id={`billing-annual-${index}`} class="hidden">
                    /año
                  </span>
                </span>
              </Text>
              <div class="mt-12">
                <Text
                  tag="p"
                  variant="textSM"
                  class={`font-medium uppercase tracking-widest ${tier.descClass}`}
                >
                  {tier.name} incluye:
                </Text>
                <ul
                  class={`flex flex-col mt-4 gap-y-3 ${tier.descClass}`}
                  role="list"
                >
                  {tier.features.map((feature) => (
                    <li class="flex items-start gap-2">
                      <Check size="sm" class="text-accent-500 shrink-0 mt-0.5" />
                      <span class="text-sm leading-normal">{feature}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </Wrapper>
</section>
<script>
  document.addEventListener("DOMContentLoaded", () => {
    const monthlyBtn = document.getElementById("monthly-pricing-button");
    const annualBtn = document.getElementById("annual-pricing-button");
    const indicator = document.getElementById("pricing-indicator");
    if (!monthlyBtn || !annualBtn || !indicator) return;
    const togglePricing = (isMonthly: boolean) => {
      [monthlyBtn, annualBtn].forEach((btn, idx) => {
        const active = idx === 0 ? isMonthly : !isMonthly;
        btn.setAttribute("aria-pressed", active.toString());
        btn.classList.toggle("text-base-950", active);
        btn.classList.toggle("text-base-400", !active);
        btn.classList.toggle("hover:text-accent-400", !active);
      });
      indicator.classList.toggle("translate-x-0", isMonthly);
      indicator.classList.toggle("translate-x-full", !isMonthly);
      document.querySelectorAll('[id^="price-amount-"]').forEach((el) => {
        if (el instanceof HTMLElement)
          el.textContent = el.dataset[isMonthly ? "monthly" : "annual"] || "";
      });
      document
        .querySelectorAll('[id^="billing-monthly-"]')
        .forEach((el) => el.classList.toggle("hidden", !isMonthly));
      document
        .querySelectorAll('[id^="billing-annual-"]')
        .forEach((el) => el.classList.toggle("hidden", isMonthly));
    };
    monthlyBtn.addEventListener("click", () => togglePricing(true));
    annualBtn.addEventListener("click", () => togglePricing(false));
  });
</script>
