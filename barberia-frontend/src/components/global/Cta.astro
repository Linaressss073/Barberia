---
import Text from "@/components/fundations/elements/Text.astro";
import Button from "@/components/fundations/elements/Button.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";

const cards = [
  {
    eyebrow: "Para clientes",
    title: "¿Eres Cliente?",
    description:
      "Crea tu cuenta gratis y reserva citas online en minutos. Elige tu barbero favorito, revisa disponibilidad y recibe recordatorios automáticos.",
    cta: "Crear Cuenta Gratis",
    href: "/signup",
    variant: "default",
    dark: false,
  },
  {
    eyebrow: "Para el negocio",
    title: "¿Eres Barbero o Dueño?",
    description:
      "Administra tu negocio desde un panel completo: agenda, clientes, ventas e inventario. Todo organizado en un solo lugar.",
    cta: "Iniciar Sesión",
    href: "/login",
    variant: "muted",
    dark: true,
  },
];
---

<section class="bg-base-900 border-y border-base-800">
  <Wrapper variant="standard" class="py-20">
    <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
      {
        cards.map((card) => (
          <div
            class:list={[
              "flex flex-col justify-between gap-8 p-8 rounded-2xl border",
              card.dark
                ? "bg-base-800 border-accent-800/40"
                : "bg-base-900 border-base-800",
            ]}
          >
            <div>
              <Text
                tag="span"
                variant="textSM"
                class="leading-normal font-medium uppercase tracking-widest text-accent-500"
              >
                {card.eyebrow}
              </Text>
              <Text
                tag="h3"
                variant="displaySM"
                class="mt-3 font-semibold tracking-tight text-base-50 font-display"
              >
                {card.title}
              </Text>
              <Text
                tag="p"
                variant="textBase"
                class="mt-3 font-medium text-base-400"
              >
                {card.description}
              </Text>
            </div>
            <Button
              isLink
              size="sm"
              variant={card.variant}
              href={card.href}
              class="w-fit"
            >
              {card.cta}
            </Button>
          </div>
        ))
      }
    </div>
  </Wrapper>
</section>
