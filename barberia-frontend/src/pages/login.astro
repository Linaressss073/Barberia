---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Button from "@/components/fundations/elements/Button.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
---

<BaseLayout>
  <section class="bg-base-950 min-h-[calc(100dvh-4rem)] flex items-center">
    <Wrapper variant="standard" class="py-20">
      <div class="max-w-sm mx-auto">
        <Text
          tag="h1"
          variant="displaySM"
          class="tracking-tight font-semibold text-base-50 font-display"
        >
          Iniciar sesión
        </Text>
        <Text
          tag="p"
          variant="textBase"
          class="mt-4 text-base-400 font-medium text-balance"
        >
          Bienvenido de vuelta. Ingresa tus datos para continuar.
        </Text>

        <div
          id="form-error"
          class="hidden mt-6 p-3 rounded-lg bg-red-900/40 border border-red-700/50"
        >
          <p class="text-sm text-red-400" id="form-error-text"></p>
        </div>

        <form id="login-form" class="mx-auto mt-8 max-w-sm" novalidate>
          <div class="flex flex-col gap-y-6">
            <div>
              <label for="email" class="text-sm text-base-400 font-medium">
                Correo electrónico
              </label>
              <div class="mt-2.5">
                <input
                  type="email"
                  name="email"
                  id="email"
                  autocomplete="email"
                  required
                  aria-required="true"
                  class="block w-full h-10 px-4 py-2 text-sm text-base-100 duration-300 bg-base-900 border border-transparent rounded-lg appearance-none ring-1 ring-base-700 placeholder-base-600 focus:border-transparent focus:outline-none focus:ring-accent-500 focus:ring-offset-2 focus:ring-offset-base-950 focus:ring-2 sm:text-sm"
                />
              </div>
            </div>
            <div>
              <label for="password" class="text-sm text-base-400 font-medium">
                Contraseña
              </label>
              <div class="mt-2.5">
                <input
                  type="password"
                  name="password"
                  id="password"
                  autocomplete="current-password"
                  required
                  aria-required="true"
                  class="block w-full h-10 px-4 py-2 text-sm text-base-100 duration-300 bg-base-900 border border-transparent rounded-lg appearance-none ring-1 ring-base-700 placeholder-base-600 focus:border-transparent focus:outline-none focus:ring-accent-500 focus:ring-offset-2 focus:ring-offset-base-950 focus:ring-2 sm:text-sm"
                />
              </div>
            </div>
          </div>
          <Button
            id="submit-btn"
            variant="default"
            size="base"
            class="mt-8 w-full"
          >
            Iniciar sesión
          </Button>
          <div class="flex items-center mt-4">
            <Text tag="p" variant="textSM" class="text-base-500">
              ¿No tienes cuenta?
              <a class="text-accent-400 hover:text-accent-300" href="/signup">
                Crear cuenta
              </a>
            </Text>
          </div>
        </form>
      </div>
    </Wrapper>
  </section>
</BaseLayout>

<script>
  import { isAuthenticated, saveSession } from "@/lib/auth";
  import { getApiV1Url } from "@/lib/config";

  if (isAuthenticated()) {
    window.location.href = "/dashboard";
  }

  const form = document.getElementById("login-form") as HTMLFormElement | null;
  const errorBox = document.getElementById("form-error") as HTMLElement | null;
  const errorText = document.getElementById(
    "form-error-text"
  ) as HTMLElement | null;
  const submitBtn = document.getElementById(
    "submit-btn"
  ) as HTMLButtonElement | null;

  function showError(msg: string) {
    if (errorText) errorText.textContent = msg;
    errorBox?.classList.remove("hidden");
  }

  function hideError() {
    errorBox?.classList.add("hidden");
  }

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    hideError();

    const fd = new FormData(form);
    const email = (fd.get("email") as string).trim();
    const password = fd.get("password") as string;

    if (!email || !password) {
      showError("Por favor completa todos los campos.");
      return;
    }

    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = "Iniciando sesión…";
    }

    try {
      const res = await fetch(`${getApiV1Url()}/auth/login`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ email, password }),
      });

      if (!res.ok) {
        const err = (await res.json().catch(() => ({}))) as {
          message?: string;
        };
        throw new Error(err.message ?? "Credenciales incorrectas");
      }

      const body = (await res.json()) as {
        data: {
          user: { id: string; email: string; fullName: string; roles: string[] };
          tokens: { accessToken: string; refreshToken: string };
        };
      };

      saveSession(
        body.data.user,
        body.data.tokens.accessToken,
        body.data.tokens.refreshToken
      );
      window.location.href = "/dashboard";
    } catch (err) {
      showError(err instanceof Error ? err.message : "Error al iniciar sesión");
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = "Iniciar sesión";
      }
    }
  });
</script>
