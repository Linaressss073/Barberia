---
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import Edit from "@/components/fundations/icons/Edit.astro";
import Complete from "@/components/fundations/icons/Complete.astro";
import Eye from "@/components/fundations/icons/Eye.astro";
import Color from "@/components/fundations/icons/Color.astro";

const features = [
  "Citas Online",
  "Gestión de Barberos",
  "Base de Clientes",
  "Control de Inventario",
  "Ventas y Caja",
  "Programa de Lealtad",
  "Reportes y Estadísticas",
  "Notificaciones",
  "Membresías",
  "Horarios y Bloques",
  "Comisiones",
  "Multi-sucursal",
];

const featureItems = [
  {
    icon: Edit,
    title: "Agenda Inteligente",
    description:
      "Reserva de citas online con barbero favorito, consulta de disponibilidad en tiempo real y recordatorios automáticos.",
  },
  {
    icon: Complete,
    title: "Clientes y Lealtad",
    description:
      "Historial completo de cada cliente, programa de puntos por visita y control de preferencias personales.",
  },
  {
    icon: Eye,
    title: "Ventas e Inventario",
    description:
      "Registro de pagos, control de productos y alertas de stock para mantener tu caja y almacén siempre al día.",
  },
  {
    icon: Color,
    title: "Reportes del Negocio",
    description:
      "Estadísticas de rendimiento, comisiones por barbero y análisis de clientes para tomar mejores decisiones.",
  },
];
---

<section id="features" class="bg-base-900 border-y border-base-800">
  <Wrapper variant="standard" class="py-20">
    <div class="text-center max-w-2xl mx-auto lg:text-balance">
      <Text
        tag="span"
        variant="textSM"
        class="leading-normal font-medium uppercase tracking-widest text-accent-500"
      >
        Funciones
      </Text>
      <Text
        tag="h2"
        variant="displayMD"
        class="tracking-tight mt-4 font-semibold text-base-50 font-display"
      >
        Todo lo que tu barbería necesita
      </Text>
      <Text tag="p" variant="textBase" class="mt-4 text-base-400 font-medium">
        La herramienta más completa para gestionar tu negocio sin complicaciones.
      </Text>
    </div>
    <div
      class="relative py-12 mx-auto overflow-hidden overflow-x-hidden 2xl:max-w-screen-xl"
    >
      <div class="grid justify-between w-full">
        <div
          class="absolute inset-0 left-0 z-10 from-base-900 via-transparent w-44 bg-gradient-to-r"
        >
        </div>
        <div
          class="absolute inset-0 left-0 z-10 ml-auto from-base-900 via-transparent w-44 bg-gradient-to-l"
        >
        </div>
      </div>
      <div class="relative flex items-center gap-2 whitespace-nowrap">
        {
          features.map((feature) => (
            <span class="inline-flex items-center font-medium relative text-accent-400 bg-base-800 border border-base-700 px-4 py-1.5 text-sm rounded-lg">
              {feature}
            </span>
          ))
        }
      </div>
    </div>
    <dl
      class="grid grid-cols-2 text-center gap-x-6 gap-y-12 lg:grid-cols-4 lg:gap-y-16"
    >
      {
        featureItems.map((item) => (
          <div>
            <div class="flex flex-col gap-3">
              <item.icon class="size-5 mx-auto text-accent-500" />
              <dt>
                <Text
                  tag="h3"
                  variant="textLG"
                  class="text-base-100 font-medium font-display"
                >
                  {item.title}
                </Text>
              </dt>
            </div>
            <dd>
              <Text tag="p" variant="textBase" class="mt-2 text-base-400">
                {item.description}
              </Text>
            </dd>
          </div>
        ))
      }
    </dl>
  </Wrapper>
</section>
