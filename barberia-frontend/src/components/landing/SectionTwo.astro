---
import { Image } from "astro:assets";
import DashboardLight from "@/images/dashboardLight.svg";
import Text from "@/components/fundations/elements/Text.astro";
import Button from "@/components/fundations/elements/Button.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import Check from "@/components/fundations/icons/Check.astro";

const sections = [
  {
    title: "Interface Sencilla",
    description:
      "Panel diseñado para usarse desde el día uno, sin necesidad de capacitación técnica.",
    features: ["Vista de agenda diaria y semanal", "Acceso completo desde celular"],
  },
  {
    title: "Analítica en Tiempo Real",
    description:
      "Entiende el rendimiento de tu negocio con reportes actualizados al instante.",
    features: ["Reportes de ventas por período", "Comisiones desglosadas por barbero"],
  },
  {
    title: "Automatizaciones",
    description:
      "Reduce el trabajo administrativo y deja que el sistema trabaje por ti.",
    features: ["Recordatorios de citas automáticos", "Alertas de inventario bajo"],
  },
];
---

<section>
  <Wrapper variant="standard" class="py-20">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 items-center">
      <div class="lg:order-last">
        <Text
          tag="span"
          variant="textSM"
          class="leading-normal font-bold uppercase text-accent-700"
        >
          Más beneficios
        </Text>
        <Text
          tag="h2"
          variant="displayMD"
          class="tracking-tight mt-4 font-semibold text-base-900"
        >
          Diseñado para el día a día de la barbería
        </Text>
        <Text tag="p" variant="textBase" class="mt-4 text-base-500 font-medium">
          Simplifica la operación y enfócate en lo que mejor sabes hacer.
        </Text>
        <div class="flex flex-wrap items-center gap-2 mx-auto mt-12">
          <Button
            variant="default"
            size="sm"
            isLink
            href="/signup">Crear Cuenta</Button
          >
          <Button
            variant="muted"
            size="sm"
            isLink
            href="#features"
          >
            Ver Funciones</Button
          >
        </div>
      </div>
      <div class="lg:col-span-2">
        <Image
          alt="Panel de gestión de barbería"
          width={900}
          height={700}
          src={DashboardLight}
          class="object-cover h-full ring-4 ring-base-50 border border-base-200 rounded-2xl"
        />
      </div>
    </div>
    <div
      class="gap-x-2 gap-y-14 mt-12 lg:gap-12 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3"
    >
      {
        sections.map((section) => (
          <div>
            <div>
              <Text tag="h3" variant="textLG" class="text-base-900 font-medium">
                {section.title}
              </Text>
              <Text tag="p" variant="textBase" class="mt-2 text-base-500">
                {section.description}
              </Text>
            </div>
            <ul
              role="list"
              class="space-y-1 mt-6 text-base font-medium text-base-900"
            >
              {section.features.map((feature) => (
                <li>
                  <div class="flex items-center gap-4">
                    <Check class="size-5 text-accent-600" />
                    <Text tag="p" variant="textSM" class="text-base-500">
                      {feature}
                    </Text>
                  </div>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </Wrapper>
</section>
