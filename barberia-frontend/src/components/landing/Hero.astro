---
import { Image } from "astro:assets";
import DashboardLight from "@/images/dashboardLight.svg";
import Text from "@/components/fundations/elements/Text.astro";
import Button from "@/components/fundations/elements/Button.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
---

<section class="overflow-hidden">
  <Wrapper class="pt-32">
    <div class="max-w-2xl text-center mx-auto lg:text-balance">
      <Text
        tag="span"
        variant="textSM"
        class="leading-normal font-bold uppercase text-accent-700"
      >
        Sistema de Gestión
      </Text>
      <Text
        tag="h1"
        variant="displayMD"
        class="tracking-tight mt-4 font-semibold text-base-900"
      >
        Tu Barbería, Siempre Organizada
      </Text>
      <Text tag="p" variant="textBase" class="mt-4 text-base-500 font-medium text-balance">
        Agenda citas, gestiona clientes, controla inventario y monitorea ventas
        desde un solo lugar. Sin complicaciones.
      </Text>
      <div class="flex flex-wrap items-center gap-2 justify-center mt-12">
        <Button
          variant="default"
          size="sm"
          isLink
          href="/signup">Crear Cuenta Gratis</Button
        >
        <Button
          variant="muted"
          size="sm"
          isLink
          href="#features"
        >
          Ver Funciones</Button
        >
      </div>
    </div>

    <div class="relative w-full mx-auto max-w-7xl items-center py-12 pb-12">
      <Image
        alt="Panel de gestión de barbería"
        width={900}
        height={700}
        src={DashboardLight}
        class="relative w-full ring-4 ring-base-50 border border-base-200 lg:rounded-2xl object-cover rounded"
      />
    </div>
  </Wrapper>
</section>
