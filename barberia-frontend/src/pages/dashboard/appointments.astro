---
import DashboardLayout from "@/layouts/DashboardLayout.astro";
---
<DashboardLayout title="Citas" section="appointments">

  <div class="space-y-5">
    <!-- Header bar -->
    <div class="flex flex-col sm:flex-row sm:items-center gap-3 sm:justify-between">
      <div class="flex items-center gap-2">
        <button id="btn-prev-day" class="p-2 rounded-lg bg-base-800 text-base-100 hover:bg-base-700 border border-base-700 transition-colors">
          <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
          </svg>
        </button>
        <span id="current-date-label" class="text-base-100 text-sm font-medium min-w-[10rem] text-center"></span>
        <button id="btn-next-day" class="p-2 rounded-lg bg-base-800 text-base-100 hover:bg-base-700 border border-base-700 transition-colors">
          <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
          </svg>
        </button>
        <button id="btn-today" class="px-3 py-1.5 text-xs rounded-lg bg-base-800 text-base-400 hover:text-base-100 hover:bg-base-700 border border-base-700 transition-colors">Hoy</button>
      </div>
      <div class="flex items-center gap-2">
        <button id="btn-refresh" class="px-3 py-2 text-xs rounded-lg bg-base-800 text-base-400 hover:text-base-100 hover:bg-base-700 border border-base-700 transition-colors">Actualizar</button>
        <a id="btn-new-appointment" href="/dashboard/book" class="hidden px-4 py-2 text-xs font-medium rounded-lg bg-accent-500 text-base-950 hover:bg-accent-400 transition-colors">+ Nueva Cita</a>
      </div>
    </div>

    <!-- Appointments table -->
    <div class="bg-base-900 border border-base-800 rounded-xl overflow-hidden">
      <table class="w-full">
        <thead>
          <tr class="bg-base-800/60">
            <th class="px-4 py-3 text-left text-xs font-medium text-base-500 uppercase tracking-widest">Hora</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-base-500 uppercase tracking-widest">Cliente</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-base-500 uppercase tracking-widest hidden sm:table-cell">Barbero</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-base-500 uppercase tracking-widest">Estado</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-base-500 uppercase tracking-widest hidden md:table-cell">Servicios</th>
            <th class="px-4 py-3 text-left text-xs font-medium text-base-500 uppercase tracking-widest hidden lg:table-cell">Fuente</th>
            <th class="px-4 py-3 text-right text-xs font-medium text-base-500 uppercase tracking-widest">Acciones</th>
          </tr>
        </thead>
        <tbody id="appointments-body" class="divide-y divide-base-800">
        </tbody>
      </table>
      <div id="appointments-empty" class="hidden p-12 text-center text-base-500 text-sm">No hay citas para este día.</div>
      <div id="appointments-loading" class="p-8 text-center text-base-500 text-sm">Cargando citas…</div>
    </div>
  </div>

  <!-- Cancel modal -->
  <div id="modal-cancel" class="fixed inset-0 z-50 flex items-center justify-center bg-black/60 hidden">
    <div class="bg-base-900 border border-base-800 rounded-2xl p-6 w-full max-w-md mx-4 shadow-2xl">
      <h3 class="text-base-100 font-semibold text-lg mb-4">Cancelar Cita</h3>
      <input type="hidden" id="cancel-apt-id" />
      <div class="space-y-3">
        <label class="text-xs uppercase tracking-widest text-base-500">Motivo (opcional)</label>
        <input id="cancel-reason" type="text" placeholder="Motivo de cancelación"
          class="bg-base-900 ring-1 ring-base-700 text-base-100 focus:ring-accent-500 focus:ring-2 focus:outline-none rounded-lg px-3 py-2 text-sm w-full" />
      </div>
      <div class="flex justify-end gap-2 mt-6">
        <button id="cancel-modal-close" class="px-4 py-2 text-sm rounded-lg bg-base-800 text-base-100 hover:bg-base-700 border border-base-700">Cerrar</button>
        <button id="cancel-modal-confirm" class="px-4 py-2 text-sm rounded-lg bg-red-700 text-white hover:bg-red-600 transition-colors">Confirmar Cancelación</button>
      </div>
    </div>
  </div>

</DashboardLayout>

<script>
  import { getUser } from "@/lib/auth";
  import { apiFetch } from "@/lib/api";

  const user = getUser();
  const roles = user.roles.map(r => r.toUpperCase());
  const isStaff = roles.some(r => ["ADMIN","RECEPTIONIST","BARBER"].includes(r));
  const isCustomer = roles.includes("CUSTOMER") && !isStaff;

  if (isStaff) {
    document.getElementById("btn-new-appointment").classList.remove("hidden");
  }

  let currentDate = new Date();
  currentDate.setHours(0,0,0,0);

  const STATUS_BADGES = {
    BOOKED:    "bg-yellow-900/40 text-yellow-400 border border-yellow-800/40",
    CONFIRMED: "bg-blue-900/40 text-blue-400 border border-blue-800/40",
    COMPLETED: "bg-green-900/40 text-green-400 border border-green-800/40",
    CANCELLED: "bg-base-700/40 text-base-500 border border-base-700/40",
    NO_SHOW:   "bg-red-900/40 text-red-400 border border-red-800/40",
  };

  const STATUS_LABELS = {
    BOOKED: "Reservada", CONFIRMED: "Confirmada", COMPLETED: "Completada",
    CANCELLED: "Cancelada", NO_SHOW: "No llegó",
  };

  function formatTime(iso) {
    return new Date(iso).toLocaleTimeString("es-CO", { hour: "2-digit", minute: "2-digit", hour12: false });
  }

  function updateDateLabel() {
    const today = new Date(); today.setHours(0,0,0,0);
    const diff = (currentDate - today) / 86400000;
    let label = currentDate.toLocaleDateString("es-CO", { weekday: "long", day: "numeric", month: "long" });
    if (diff === 0) label = "Hoy — " + label;
    else if (diff === 1) label = "Mañana — " + label;
    else if (diff === -1) label = "Ayer — " + label;
    document.getElementById("current-date-label").textContent = label;
  }

  async function loadAppointments() {
    const body = document.getElementById("appointments-body");
    const empty = document.getElementById("appointments-empty");
    const loading = document.getElementById("appointments-loading");
    body.innerHTML = "";
    empty.classList.add("hidden");
    loading.classList.remove("hidden");

    try {
      let data;
      if (isCustomer) {
        const now = new Date();
        const from = now.toISOString();
        const to = new Date(now.getTime() + 30*24*60*60*1000).toISOString();
        data = await apiFetch(`/appointments?from=${from}&to=${to}&customerId=${user.id}&limit=50&page=1`);
      } else {
        const from = new Date(currentDate); from.setHours(0,0,0,0);
        const to = new Date(currentDate); to.setHours(23,59,59,999);
        data = await apiFetch(`/appointments?from=${from.toISOString()}&to=${to.toISOString()}&limit=100&page=1`);
      }

      loading.classList.add("hidden");
      const items = data.items ?? data ?? [];

      if (items.length === 0) {
        empty.classList.remove("hidden");
        return;
      }

      items.forEach(apt => {
        const tr = document.createElement("tr");
        tr.className = "hover:bg-base-800/30 transition-colors";

        const status = apt.status ?? "BOOKED";
        const badgeCls = STATUS_BADGES[status] ?? STATUS_BADGES.BOOKED;
        const serviceCount = apt.serviceIds?.length ?? apt.services?.length ?? 0;
        const source = apt.source ?? "MANUAL";

        let actionButtons = "";
        if (isStaff) {
          if (status === "BOOKED") {
            actionButtons = `
              <button class="btn-action px-2.5 py-1 text-xs rounded-md bg-blue-900/40 text-blue-400 border border-blue-800/40 hover:bg-blue-800/60 transition-colors" data-id="${apt.id}" data-action="confirm">Confirmar</button>
              <button class="btn-action px-2.5 py-1 text-xs rounded-md bg-red-900/30 text-red-400 border border-red-800/30 hover:bg-red-800/40 transition-colors" data-id="${apt.id}" data-action="cancel">Cancelar</button>`;
          } else if (status === "CONFIRMED") {
            actionButtons = `
              <button class="btn-action px-2.5 py-1 text-xs rounded-md bg-green-900/40 text-green-400 border border-green-800/40 hover:bg-green-800/60 transition-colors" data-id="${apt.id}" data-action="complete">Completar</button>
              <button class="btn-action px-2.5 py-1 text-xs rounded-md bg-yellow-900/30 text-yellow-400 border border-yellow-800/30 hover:bg-yellow-800/40 transition-colors" data-id="${apt.id}" data-action="no-show">No llegó</button>
              <button class="btn-action px-2.5 py-1 text-xs rounded-md bg-red-900/30 text-red-400 border border-red-800/30 hover:bg-red-800/40 transition-colors" data-id="${apt.id}" data-action="cancel">Cancelar</button>`;
          }
        } else if (isCustomer) {
          if (status === "BOOKED" || status === "CONFIRMED") {
            actionButtons = `
              <button class="btn-action px-2.5 py-1 text-xs rounded-md bg-red-900/30 text-red-400 border border-red-800/30 hover:bg-red-800/40 transition-colors" data-id="${apt.id}" data-action="cancel">Cancelar</button>`;
          }
        }

        const barberName = apt.barber?.displayName ?? apt.barberId ?? "—";
        const customerName = apt.customer?.fullName ?? apt.customerId ?? "—";

        tr.innerHTML = `
          <td class="px-4 py-3 text-sm text-base-100">${formatTime(apt.scheduledAt)}</td>
          <td class="px-4 py-3 text-sm text-base-100">${customerName}</td>
          <td class="px-4 py-3 text-sm text-base-400 hidden sm:table-cell">${barberName}</td>
          <td class="px-4 py-3">
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium ${badgeCls}">${STATUS_LABELS[status] ?? status}</span>
          </td>
          <td class="px-4 py-3 text-sm text-base-400 hidden md:table-cell">${serviceCount} servicio${serviceCount !== 1 ? "s" : ""}</td>
          <td class="px-4 py-3 text-xs text-base-500 hidden lg:table-cell">${source}</td>
          <td class="px-4 py-3 text-right">
            <div class="flex items-center justify-end gap-1.5 flex-wrap">${actionButtons}</div>
          </td>`;
        body.appendChild(tr);
      });

      body.querySelectorAll(".btn-action").forEach(btn => {
        btn.addEventListener("click", () => handleAction(btn.dataset.id, btn.dataset.action));
      });
    } catch (err) {
      loading.classList.add("hidden");
      empty.classList.remove("hidden");
      window.toast(err.message ?? "Error al cargar citas", "error");
    }
  }

  async function handleAction(id, action) {
    if (action === "cancel") {
      document.getElementById("cancel-apt-id").value = id;
      document.getElementById("cancel-reason").value = "";
      document.getElementById("modal-cancel").classList.remove("hidden");
      return;
    }
    try {
      await apiFetch(`/appointments/${id}/${action}`, { method: "PATCH" });
      window.toast("Cita actualizada correctamente", "success");
      loadAppointments();
    } catch (err) {
      window.toast(err.message ?? "Error al actualizar cita", "error");
    }
  }

  document.getElementById("btn-prev-day").addEventListener("click", () => {
    currentDate.setDate(currentDate.getDate() - 1);
    updateDateLabel();
    loadAppointments();
  });

  document.getElementById("btn-next-day").addEventListener("click", () => {
    currentDate.setDate(currentDate.getDate() + 1);
    updateDateLabel();
    loadAppointments();
  });

  document.getElementById("btn-today").addEventListener("click", () => {
    currentDate = new Date(); currentDate.setHours(0,0,0,0);
    updateDateLabel();
    loadAppointments();
  });

  document.getElementById("btn-refresh").addEventListener("click", loadAppointments);

  document.getElementById("modal-cancel").addEventListener("click", (e) => {
    if (e.target === e.currentTarget) e.currentTarget.classList.add("hidden");
  });
  document.getElementById("cancel-modal-close").addEventListener("click", () => {
    document.getElementById("modal-cancel").classList.add("hidden");
  });
  document.getElementById("cancel-modal-confirm").addEventListener("click", async () => {
    const id = document.getElementById("cancel-apt-id").value;
    const reason = document.getElementById("cancel-reason").value.trim();
    try {
      await apiFetch(`/appointments/${id}/cancel`, {
        method: "PATCH",
        body: JSON.stringify(reason ? { reason } : {}),
      });
      document.getElementById("modal-cancel").classList.add("hidden");
      window.toast("Cita cancelada", "success");
      loadAppointments();
    } catch (err) {
      window.toast(err.message ?? "Error al cancelar", "error");
    }
  });

  updateDateLabel();
  loadAppointments();
</script>
